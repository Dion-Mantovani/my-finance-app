---
import MainLayout from '../layouts/MainLayout.astro'
import UserHeader from '../components/home/UserHeader.astro'
import BalanceCard from '../components/home/BalanceCard.astro'
import StatCard from '../components/home/StatCard.astro'
import TransactionItem from '../components/shared/TransactionItem.astro'
import EmptyState from '../components/shared/EmptyState.astro'

// Kita biarkan transactions kosong di server, nanti diisi via Alpine di client
---

<MainLayout title="Overview">
  <div class="pb-[15vh]" x-data="homeDashboard">
    <UserHeader />

    <!-- ALERT -->
    <div class="my-5" x-show="getDailyInsight()">
      <div
        :class="getDailyInsight().type === 'warning' ? 'bg-rose-50 border-rose-100' : 'bg-indigo-50 border-indigo-100'"
        class="flex items-center gap-4 rounded-4xl border p-4 transition-all"
      >
        <div
          :class="getDailyInsight().type === 'warning' ? 'text-rose-500 border-rose-100' : 'text-indigo-500 border-indigo-100'"
          class="flex h-11 w-11 shrink-0 items-center justify-center rounded-2xl border bg-white shadow-sm"
        >
          <i :class="getDailyInsight().icon" class="fa-solid"></i>
        </div>
        <div class="flex-1">
          <p
            :class="getDailyInsight().type === 'warning' ? 'text-rose-400' : 'text-indigo-400'"
            class="mb-0.5 text-[10px] font-black tracking-[0.15em] uppercase"
            x-text="getDailyInsight().label"
          >
          </p>

          <p
            class="text-sm leading-snug font-bold text-slate-700"
            x-html="getDailyInsight().message"
          >
          </p>
        </div>
      </div>
    </div>

    <!-- BALANCE CARD -->
    <BalanceCard lastUpdated="2 min ago" />

    <!-- MONTHLY STAT -->
    <section class="mb-8 grid grid-cols-2 gap-2">
      <StatCard type="income" title="Income" alpineValue="monthlyIncome" />
      <StatCard type="expense" title="Expense" alpineValue="monthlyExpense" />
    </section>

    <!-- CRITICAL BUDGET LIST -->
    <template x-if="criticalBudgets.length > 0">
      <section class="mb-5">
        <header class="mb-1 flex items-center justify-between px-6">
          <div class="flex items-center gap-2">
            <h3 class="color-app-text text-xl font-bold">Critical Limits</h3>
            <span class="relative flex h-2 w-2">
              <span
                class="absolute inline-flex h-full w-full animate-ping rounded-full bg-rose-400 opacity-75"
              ></span>
              <span
                class="relative inline-flex h-2 w-2 rounded-full bg-rose-500"
              ></span>
            </span>
          </div>
          <a
            href="/budget"
            class="group flex items-center gap-2 rounded-full py-1.5 transition-all duration-300 hover:bg-indigo-50"
          >
            <span
              class="text-[10px] font-black tracking-[0.15em] text-indigo-600 uppercase"
              >View All</span
            >
          </a>
        </header>

        <div class="grid grid-cols-1 gap-4">
          <template x-for="budget in criticalBudgets" :key="budget.id">
            <a
              href="/budget"
              class="group relative overflow-hidden rounded-4xl border border-rose-100 bg-linear-to-br from-rose-50/80 to-white p-5 shadow-xl shadow-slate-100 transition-all active:scale-[0.97]"
            >
              <div
                class="absolute -top-4 -right-4 h-20 w-20 rounded-full bg-rose-100/30 blur-2xl transition-colors group-hover:bg-rose-200/40"
              >
              </div>

              <div class="relative z-10">
                <div class="mb-4 flex items-start justify-between">
                  <div class="flex items-center gap-4">
                    <div
                      :class="budget.color || 'bg-indigo-600'"
                      class="flex h-11 w-11 items-center justify-center rounded-2xl text-white shadow-sm shadow-rose-200"
                    >
                      <i
                        class="fa-solid text-sm"
                        :class="getCategoryIcon(budget.category)"></i>
                    </div>
                    <div>
                      <h4
                        class="text-sm font-black text-[#1D1E20]"
                        x-text="budget.category"
                      >
                      </h4>
                      <p
                        class="text-[10px] font-bold tracking-wider text-rose-500 uppercase"
                        x-text="Math.round(budget.percentage) + '% Used'"
                      >
                      </p>
                    </div>
                  </div>
                  <div class="text-right">
                    <p
                      class="mb-1 text-[10px] font-bold tracking-widest text-slate-500 uppercase"
                    >
                      Remaining
                    </p>
                    <p
                      class="text-sm font-black text-slate-700"
                      x-text="'Rp ' + budget.remaining.toLocaleString('id-ID')"
                    >
                    </p>
                  </div>
                </div>

                <div
                  class="relative h-3 w-full overflow-hidden rounded-full border border-rose-50 bg-white p-0.5"
                >
                  <div
                    class="h-full rounded-full bg-linear-to-r from-rose-400 to-rose-600 shadow-[0_0_8px_rgba(244,63,94,0.4)] transition-all duration-1000"
                    :style="`width: ${budget.percentage}%`"
                  >
                  </div>
                </div>
              </div>
            </a>
          </template>
        </div>
      </section>
    </template>

    <!-- RECENT ACTIVITY -->
    <section>
      <header class="mb-1 flex items-center justify-between px-6">
        <h3 class="color-app-text text-xl font-bold">Recent Activity</h3>
        <a
          href="/expense"
          class="group flex items-center gap-2 rounded-full py-1.5 transition-all duration-300 hover:bg-indigo-50"
        >
          <span
            class="text-[10px] font-black tracking-[0.15em] text-indigo-600 uppercase"
            >View All</span
          >
        </a>
      </header>

      <div
        class="rounded-4xl border border-slate-100 bg-white shadow-xl shadow-slate-100"
      >
        <template x-if="transactions.length > 0">
          <div class="my-4 space-y-3 px-4">
            <template x-for="item in transactions.slice(0, 3)" :key="item.id">
              <TransactionItem />
            </template>
          </div>
        </template>

        <template x-if="transactions.length === 0">
          <EmptyState
            title="No Activity Yet"
            message="Start tracking your expenses to see them here."
            buttonText="Add Transaction"
            icon="fa-list-check"
            type="link"
            link="/transactions"
          />
        </template>
      </div>
    </section>
  </div>
</MainLayout>

<script>
  import { storage } from '../utils/storage'

  document.addEventListener('alpine:init', () => {
    ;(window as any).homeDashboard = () => ({
      transactions: [],
      totalAsset: '0',
      monthlyIncome: '0',
      monthlyExpense: '0',
      showAmount: storage.getPrivacy(), // Ambil status awal
      dailyExpense: '0',
      criticalBudgets: [],

      init() {
        // CEK & INITIALIZE SETTINGS JIKA KOSONG
        const currentSettings = localStorage.getItem('DION_SETTINGS')
        if (!currentSettings) {
          // Panggil getSettings sekali untuk memicu DEFAULT_SETTINGS
          const defaults = storage.getSettings()
          storage.saveSettings(defaults)
          console.log('Settings initialized with defaults')
        }

        this.refreshData()

        // Listener agar data update otomatis jika ada perubahan di storage (dari tab lain)
        window.addEventListener('storage', (e) => {
          if (e.key === 'DION_PRIVACY') {
            this.showAmount = storage.getPrivacy()
          }
          this.refreshData()
        })
      },

      getGreeting() {
        const hour = new Date().getHours()
        if (hour < 11) return { title: 'Hello, Good Morning', icon: '☀️' }
        if (hour < 15) return { title: 'Hello, Good Afternoon', icon: '🌤️' }
        if (hour < 19) return { title: 'Hello, Good Evening', icon: '🌆' }
        return { title: 'Good Night', icon: '🌙' }
      },

      togglePrivacy() {
        const newState = !this.showAmount
        this.showAmount = newState
        storage.setPrivacy(newState)
        // Trigger event agar tab/halaman lain tau
        window.dispatchEvent(new Event('storage'))
      },

      refreshData() {
        const allTrans = storage.getTransactions()
        const balances = storage.getBalances()
        const transactions = storage.getTransactions() || []
        const settings = storage.getSettings() || {}
        const wallets = settings.wallets || []
        const budgets = settings.budgets || []
        const today = new Date()
        today.setHours(0, 0, 0, 0)

        this.transactions = transactions.map((item: any) => {
          // Cari nama wallet asal berdasarkan ID
          const source = wallets.find((w: any) => w.id === item.walletId)

          // Cari nama wallet tujuan (kalau tipenya transfer)
          const dest = item.walletIdDest
            ? wallets.find((w: any) => w.id === item.walletIdDest)
            : null

          return {
            ...item,
            // Kita "suntik" properti walletSource agar komponen gak perlu berubah
            walletSource: source ? source.name : 'Unknown Wallet',
            walletDestName: dest ? dest.name : '',
          }
        })

        // Daily Insight
        this.totalAsset = balances.totalAsset.toLocaleString('id-ID')

        const expenseToday = allTrans
          .filter((t: any) => {
            const transDate = new Date(t.date)
            transDate.setHours(0, 0, 0, 0)
            return (
              t.type === 'expense' && transDate.getTime() === today.getTime()
            )
          })
          .reduce((sum: any, t: any) => sum + Number(t.amount), 0)

        this.dailyExpense =
          expenseToday === 0 ? '0' : expenseToday.toLocaleString('id-ID')

        // Hitung income & expense bulan ini sederhana
        const now = new Date()
        const thisMonth = allTrans.filter((t: any) => {
          const d = new Date(t.date)
          return (
            d.getMonth() === now.getMonth() &&
            d.getFullYear() === now.getFullYear()
          )
        })

        const income = thisMonth
          .filter((t: any) => t.type === 'income')
          .reduce((sum: any, t: any) => sum + Number(t.amount), 0)

        const expense = thisMonth
          .filter((t: any) => t.type === 'expense')
          .reduce((sum: any, t: any) => sum + Number(t.amount), 0)

        this.monthlyIncome = income.toLocaleString('id-ID')
        this.monthlyExpense = expense.toLocaleString('id-ID')

        // LOGIC BUDGET ALERT
        this.criticalBudgets = budgets
          // 1. Filter bulan & tahun ini [cite: 33, 41]
          .filter(
            (b: any) =>
              b.month === now.getMonth() && b.year === now.getFullYear()
          )
          .map((b: any) => {
            const used = allTrans
              .filter(
                (t: any) =>
                  t.type === 'expense' &&
                  t.category === b.category &&
                  new Date(t.date).getMonth() === now.getMonth()
              )
              .reduce((sum: number, t: any) => sum + Number(t.amount), 0)

            return {
              ...b,
              used,
              percentage: (used / b.limit) * 100,
              remaining: b.limit - used,
            }
          })
          // 2. Hanya yang di atas 90%
          .filter((b: any) => b.percentage >= 90)
          // 3. Urutkan dari yang paling kritis (persentase tertinggi)
          .sort((a: any, b: any) => b.percentage - a.percentage)
          // 4. Ambil maksimal 2 data
          .slice(0, 2)
      },

      // Di dalam homeDashboard index.astro
      getDailyInsight() {
        // 1. Cari budget paling kritis (di atas 80%) [cite: 36, 60]
        const settings = storage.getSettings() || {}
        const budgets = settings.budgets || []

        // Logic refreshBudget versi mini untuk dapetin percentage tiap budget [cite: 31-37]
        const criticalBudget = budgets
          .map((b: any) => {
            const used = storage
              .getTransactions()
              .filter(
                (t: any) => t.type === 'expense' && t.category === b.category
              )
              .reduce((sum: any, t: any) => sum + Number(t.amount), 0)
            return { ...b, percentage: (used / b.limit) * 100 }
          })
          .find((b: any) => b.percentage >= 80)

        if (criticalBudget) {
          return {
            type: 'warning',
            icon: 'fa-triangle-exclamation',
            label: 'Attention Needed',
            message: `Your <span class="text-rose-600">${criticalBudget.category}</span> budget is almost empty (${Math.round(criticalBudget.percentage)}%). Take it easy! 💸`,
          }
        }

        // 2. Fallback: Kalau semua budget aman, kasih motivasi harian
        if (this.dailyExpense === '0') {
          return {
            type: 'info',
            icon: 'fa-leaf',
            label: 'Daily Status',
            message:
              "Clean slate! You haven't spent anything yet today. Your wallet is happy! ✨",
          }
        }

        return {
          type: 'info',
          icon: 'fa-chart-line',
          label: 'Spending Trend',
          message: `You've used <span class="text-indigo-600">Rp ${this.dailyExpense}</span> today. Everything looks under control. 🚀`,
        }
      },

      getCategoryIcon(categoryName: string) {
        // Tambahkan [key: string]: string agar TypeScript tidak protes
        const categories: { [key: string]: string } = {
          Makan: 'fa-bowl-food',
          Transport: 'fa-car',
          Hiburan: 'fa-clapperboard',
          Kesehatan: 'fa-heart-pulse',
          Belanja: 'fa-bag-shopping',
          Tagihan: 'fa-file-invoice-dollar',
          Rokok: 'fa-smoking',
          Default: 'fa-wallet',
        }

        return categories[categoryName] || categories['Default']
      },
    })
  })
</script>
