---
import MainLayout from '../layouts/MainLayout.astro'
import UserHeader from '../components/home/UserHeader.astro'
import BalanceCard from '../components/home/BalanceCard.astro'
import StatCard from '../components/home/StatCard.astro'
import TransactionItem from '../components/shared/TransactionItem.astro'
import EmptyState from '../components/shared/EmptyState.astro'
---

<MainLayout title="Overview">
  <div class="pb-[15vh]" x-data="homeDashboard">
    <UserHeader />

    <!-- ALERT -->
    <div
      x-show="getDailyInsight()"
      x-transition.duration.300ms
      class="relative my-5"
    >
      <div
        :class="getDailyInsight()?.type === 'warning' ? 'bg-rose-50/90 border-rose-100 shadow-rose-100/50' : 'bg-indigo-50/90 border-indigo-100 shadow-indigo-100/30'"
        class="flex items-center gap-4 rounded-3xl border p-4 pr-11 shadow-xl transition-all"
      >
        <div
          :class="getDailyInsight()?.type === 'warning' ? 'text-rose-500 border-rose-100' : 'text-indigo-500 border-indigo-100'"
          class="flex h-10 w-10 shrink-0 items-center justify-center rounded-xl border bg-white shadow-xs"
        >
          <i :class="getDailyInsight()?.icon" class="fa-solid text-sm"></i>
        </div>

        <div class="flex-1">
          <p
            :class="getDailyInsight()?.type === 'warning' ? 'text-rose-500/80' : 'text-indigo-500/80'"
            class="font-jakarta mb-0.5 text-[9px] font-black tracking-widest uppercase"
            x-text="getDailyInsight()?.label"
          >
          </p>

          <div
            class="font-jakarta text-xs leading-relaxed font-bold text-slate-700"
            x-html="getDailyInsight()?.message"
          >
          </div>
        </div>

        <button
          @click="dismissAlert()"
          class="absolute top-4 right-4 flex h-6 w-6 items-center justify-center rounded-full opacity-30 transition-all hover:bg-black/5 hover:opacity-100 active:scale-90"
          title="Sembunyikan Alert"
        >
          <i class="fa-solid fa-xmark text-xs"></i>
        </button>
      </div>
    </div>

    <!-- BALANCE CARD -->
    <BalanceCard incomeValue="monthlyIncome" expenseValue="monthlyExpense" />

    <!-- CONTAINER FEATURE -->
    <section class="my-7 text-indigo-950">
      <div class="w-full">
        <div class="mb-1 px-5">
          <h3
            class="color-app-text text-xs font-bold tracking-widest uppercase"
          >
            More Features
          </h3>
        </div>

        <div class="grid grid-cols-5 gap-2 px-2">
          <div class="flex flex-col items-center justify-center py-2">
            <div
              class="mb-1.5 flex h-9 w-9 items-center justify-center rounded-xl bg-slate-800 text-amber-400 opacity-40"
            >
              <i class="fa-solid fa-tags text-sm"></i>
            </div>
            <span class="text-[10px] font-bold text-slate-400">Cats</span>
          </div>

          <div class="flex flex-col items-center justify-center py-2">
            <div
              class="mb-1.5 flex h-9 w-9 items-center justify-center rounded-xl bg-slate-800 text-indigo-400 opacity-40"
            >
              <i class="fa-solid fa-bullseye text-sm"></i>
            </div>
            <span class="text-[10px] font-bold text-slate-400">Goals</span>
          </div>

          <div class="flex flex-col items-center justify-center py-2">
            <div
              class="mb-1.5 flex h-9 w-9 items-center justify-center rounded-xl bg-slate-800 text-emerald-400 opacity-40"
            >
              <i class="fa-solid fa-hand-holding-dollar text-sm"></i>
            </div>
            <span class="text-[10px] font-bold text-slate-400">Debts</span>
          </div>

          <div class="flex flex-col items-center justify-center py-2">
            <div
              class="mb-1.5 flex h-9 w-9 items-center justify-center rounded-xl bg-slate-800 text-rose-400 opacity-40"
            >
              <i class="fa-solid fa-calendar-check text-sm"></i>
            </div>
            <span class="text-[10px] font-bold text-slate-400">Subs</span>
          </div>

          <button
            @click=""
            class="flex flex-col items-center justify-center py-2 text-slate-400 transition-all hover:text-white active:scale-95"
          >
            <div
              class="mb-1.5 flex h-9 w-9 items-center justify-center rounded-xl border border-white/10 bg-slate-400/10 opacity-40 backdrop-blur-md transition-colors hover:bg-white/10"
            >
              <i class="fa-solid fa-ellipsis text-sm text-indigo-950"></i>
            </div>
            <span class="text-[10px] font-bold">Other</span>
          </button>
        </div>
      </div>
    </section>

    <!-- DAILY GRAPH -->
    <section class="mb-4">
      <div
        class="relative rounded-4xl bg-transparent text-indigo-950 shadow-2xl shadow-slate-300/5"
      >
        <div class="flex items-center justify-between px-5">
          <h3
            class="color-app-text text-xs font-bold tracking-widest uppercase"
          >
            Weekly Expense
          </h3>
          <div class="flex gap-4">
            <div class="flex items-center gap-1.5">
              <div class="h-2 w-2 rounded-full bg-indigo-400"></div>
              <span class="text-[9px] font-bold text-slate-400 uppercase"
                >Expense</span
              >
            </div>
          </div>
        </div>

        <div class="min-h-45 w-full" x-ref="chartCanvasHome"></div>
      </div>
    </section>

    <!-- CRITICAL BUDGET LIST -->
    <template x-if="criticalBudgets.length > 0">
      <section class="mb-8">
        <header class="mb-1 flex items-center justify-between px-6">
          <div class="flex items-center gap-2">
            <!-- <h3 class="color-app-text text-xl font-bold">Critical Limits</h3> -->
            <h3
              class="color-app-text text-xs font-bold tracking-widest uppercase"
            >
              Critical Limits
            </h3>
            <span class="relative flex h-2 w-2">
              <span
                class="absolute inline-flex h-full w-full animate-ping rounded-full bg-rose-400 opacity-75"
              ></span>
              <span
                class="relative inline-flex h-2 w-2 rounded-full bg-rose-500"
              ></span>
            </span>
          </div>
          <a
            href="/budget"
            class="group flex items-center gap-2 rounded-full py-1.5 transition-all duration-300 hover:bg-indigo-50"
          >
            <span
              class="text-[10px] font-black tracking-[0.15em] text-indigo-600 uppercase"
              >View All</span
            >
          </a>
        </header>

        <div class="grid grid-cols-1 gap-3">
          <template x-for="budget in criticalBudgets" :key="budget.id">
            <a
              href="/budget"
              class="group relative block overflow-hidden rounded-3xl border border-rose-100 bg-white p-4 shadow-xl shadow-slate-100/40 transition-all active:scale-[0.98]"
            >
              <div
                class="absolute -top-6 -right-6 h-16 w-16 rounded-full bg-rose-50 blur-xl transition-colors group-hover:bg-rose-100/60"
              >
              </div>

              <div class="relative z-10 flex flex-col gap-2.5">
                <div class="flex items-center justify-between">
                  <div class="flex items-center gap-3">
                    <div
                      :class="budget.color || 'bg-indigo-600'"
                      class="flex h-9 w-9 items-center justify-center rounded-xl text-white shadow-sm shadow-slate-100"
                    >
                      <i
                        class="fa-solid text-xs"
                        :class="storage.getCategoryIcon(budget.category)"></i>
                    </div>

                    <div>
                      <h4
                        class="text-xs font-bold tracking-wide text-[#1D1E20]"
                        x-text="budget.category"
                      >
                      </h4>
                      <p
                        class="mt-0.5 text-[9px] font-bold tracking-wider text-rose-500 uppercase"
                        x-text="Math.round(budget.percentage) + '% Used'"
                      >
                      </p>
                    </div>
                  </div>

                  <div class="text-right">
                    <p
                      class="mb-0.5 text-[9px] font-bold tracking-widest text-slate-400 uppercase"
                    >
                      Remaining
                    </p>
                    <h5
                      x-show="$store.app.showAmount"
                      class="text-xs font-black text-slate-700"
                      x-text="'Rp ' + budget.remaining"
                    >
                    </h5>
                    <span
                      x-show="!$store.app.showAmount"
                      class="text-xs font-black text-slate-700"
                      x-cloak>RP •••</span
                    >
                  </div>
                </div>

                <div
                  class="relative h-1.5 w-full overflow-hidden rounded-full bg-rose-50 p-0"
                >
                  <div
                    class="h-full rounded-full bg-linear-to-r from-rose-400 to-rose-500 shadow-[0_0_6px_rgba(251,113,133,0.3)] transition-all duration-1000"
                    :style="`width: ${Math.min(budget.percentage, 100)}%`"
                  >
                  </div>
                </div>
              </div>
            </a>
          </template>
        </div>
      </section>
    </template>

    <!-- RECENT ACTIVITY -->
    <section>
      <header class="mb-1 flex items-center justify-between px-6">
        <!-- <h3 class="color-app-text text-xl font-bold">Recent Activity</h3> -->
        <h3 class="color-app-text text-xs font-bold tracking-widest uppercase">
          Recent Activity
        </h3>
        <a
          href="/expense"
          class="group flex items-center gap-2 rounded-full py-1.5 transition-all duration-300 hover:bg-indigo-50"
        >
          <span
            class="text-[10px] font-black tracking-[0.15em] text-indigo-600 uppercase"
            >View All</span
          >
        </a>
      </header>

      <div
        class="rounded-4xl border border-slate-100 bg-white shadow-xl shadow-slate-100"
      >
        <template x-if="transactions.length > 0">
          <div class="my-4 space-y-3 px-4">
            <template x-for="item in transactions.slice(0, 3)" :key="item.id">
              <TransactionItem />
            </template>
          </div>
        </template>

        <template x-if="transactions.length === 0">
          <EmptyState
            title="No Activity Yet"
            message="Start tracking your expenses to see them here."
            buttonText="Add Transaction"
            icon="fa-list-check"
            type="link"
            link="/transactions"
          />
        </template>
      </div>
    </section>
  </div>
</MainLayout>

<script>
  import Alpine from 'alpinejs'
  import { homeDashboard } from '../logic/home'

  // Daftarkan ke Alpine
  document.addEventListener('alpine:init', () => {
    Alpine.data('homeDashboard', homeDashboard)
  })
</script>
