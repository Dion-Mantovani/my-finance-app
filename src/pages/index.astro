---
import MainLayout from '../layouts/MainLayout.astro'
import UserHeader from '../components/home/UserHeader.astro'
import BalanceCard from '../components/home/BalanceCard.astro'
import StatCard from '../components/home/StatCard.astro'
import TransactionItem from '../components/shared/TransactionItem.astro'
import EmptyState from '../components/shared/EmptyState.astro'
---

<MainLayout title="Overview">
  <div class="pb-[15vh]" x-data="homeDashboard">
    <UserHeader />

    <!-- ALERT -->
    <div class="my-5" x-show="getDailyInsight()">
      <div
        :class="getDailyInsight().type === 'warning' ? 'bg-rose-50 border-rose-100' : 'bg-indigo-50 border-indigo-100'"
        class="flex items-center gap-4 rounded-4xl border p-4 transition-all"
      >
        <div
          :class="getDailyInsight().type === 'warning' ? 'text-rose-500 border-rose-100' : 'text-indigo-500 border-indigo-100'"
          class="flex h-11 w-11 shrink-0 items-center justify-center rounded-2xl border bg-white shadow-sm"
        >
          <i :class="getDailyInsight().icon" class="fa-solid"></i>
        </div>
        <div class="flex-1">
          <p
            :class="getDailyInsight().type === 'warning' ? 'text-rose-400' : 'text-indigo-400'"
            class="mb-0.5 text-[10px] font-black tracking-[0.15em] uppercase"
            x-text="getDailyInsight().label"
          >
          </p>

          <p
            class="text-sm leading-snug font-bold text-slate-700"
            x-html="getDailyInsight().message"
          >
          </p>
        </div>
      </div>
    </div>

    <!-- BALANCE CARD -->
    <BalanceCard lastUpdated="2 min ago" />

    <!-- MONTHLY STAT -->
    <section class="mb-8 grid grid-cols-2 gap-2">
      <StatCard type="income" title="Income" alpineValue="monthlyIncome" />
      <StatCard type="expense" title="Expense" alpineValue="monthlyExpense" />
    </section>

    <!-- CRITICAL BUDGET LIST -->
    <template x-if="criticalBudgets.length > 0">
      <section class="mb-5">
        <header class="mb-1 flex items-center justify-between px-6">
          <div class="flex items-center gap-2">
            <h3 class="color-app-text text-xl font-bold">Critical Limits</h3>
            <span class="relative flex h-2 w-2">
              <span
                class="absolute inline-flex h-full w-full animate-ping rounded-full bg-rose-400 opacity-75"
              ></span>
              <span
                class="relative inline-flex h-2 w-2 rounded-full bg-rose-500"
              ></span>
            </span>
          </div>
          <a
            href="/budget"
            class="group flex items-center gap-2 rounded-full py-1.5 transition-all duration-300 hover:bg-indigo-50"
          >
            <span
              class="text-[10px] font-black tracking-[0.15em] text-indigo-600 uppercase"
              >View All</span
            >
          </a>
        </header>

        <div class="grid grid-cols-1 gap-4">
          <template x-for="budget in criticalBudgets" :key="budget.id">
            <a
              href="/budget"
              class="group relative overflow-hidden rounded-4xl border border-rose-100 bg-linear-to-br from-rose-50/80 to-white p-5 shadow-xl shadow-slate-100 transition-all active:scale-[0.97]"
            >
              <div
                class="absolute -top-4 -right-4 h-20 w-20 rounded-full bg-rose-100/30 blur-2xl transition-colors group-hover:bg-rose-200/40"
              >
              </div>

              <div class="relative z-10">
                <div class="mb-4 flex items-start justify-between">
                  <div class="flex items-center gap-4">
                    <div
                      :class="budget.color || 'bg-indigo-600'"
                      class="flex h-11 w-11 items-center justify-center rounded-2xl text-white shadow-sm shadow-rose-200"
                    >
                      <i
                        class="fa-solid text-sm"
                        :class="storage.getCategoryIcon(budget.category)"></i>
                    </div>
                    <div>
                      <h4
                        class="text-sm font-black text-[#1D1E20]"
                        x-text="budget.category"
                      >
                      </h4>
                      <p
                        class="text-[10px] font-bold tracking-wider text-rose-500 uppercase"
                        x-text="Math.round(budget.percentage) + '% Used'"
                      >
                      </p>
                    </div>
                  </div>
                  <div class="text-right">
                    <p
                      class="mb-1 text-[10px] font-bold tracking-widest text-slate-500 uppercase"
                    >
                      Remaining
                    </p>
                    <p
                      x-show="$store.app.showAmount"
                      class="text-sm font-black text-slate-700"
                      x-text="'Rp ' + budget.remaining"
                    >
                    </p>
                    <span
                      x-show="!$store.app.showAmount"
                      class="text-sm font-black text-slate-700"
                      x-cloak>RP •••</span
                    >
                  </div>
                </div>

                <div
                  class="relative h-3 w-full overflow-hidden rounded-full border border-rose-50 bg-white p-0.5"
                >
                  <div
                    class="h-full rounded-full bg-linear-to-r from-rose-400 to-rose-600 shadow-[0_0_8px_rgba(244,63,94,0.4)] transition-all duration-1000"
                    :style="`width: ${budget.percentage}%`"
                  >
                  </div>
                </div>
              </div>
            </a>
          </template>
        </div>
      </section>
    </template>

    <!-- RECENT ACTIVITY -->
    <section>
      <header class="mb-1 flex items-center justify-between px-6">
        <h3 class="color-app-text text-xl font-bold">Recent Activity</h3>
        <a
          href="/expense"
          class="group flex items-center gap-2 rounded-full py-1.5 transition-all duration-300 hover:bg-indigo-50"
        >
          <span
            class="text-[10px] font-black tracking-[0.15em] text-indigo-600 uppercase"
            >View All</span
          >
        </a>
      </header>

      <div
        class="rounded-4xl border border-slate-100 bg-white shadow-xl shadow-slate-100"
      >
        <template x-if="transactions.length > 0">
          <div class="my-4 space-y-3 px-4">
            <template x-for="item in transactions.slice(0, 3)" :key="item.id">
              <TransactionItem />
            </template>
          </div>
        </template>

        <template x-if="transactions.length === 0">
          <EmptyState
            title="No Activity Yet"
            message="Start tracking your expenses to see them here."
            buttonText="Add Transaction"
            icon="fa-list-check"
            type="link"
            link="/transactions"
          />
        </template>
      </div>
    </section>
  </div>
</MainLayout>

<script>
  import Alpine from 'alpinejs'
  import { homeDashboard } from '../logic/home'

  // Daftarkan ke Alpine
  document.addEventListener('alpine:init', () => {
    Alpine.data('homeDashboard', homeDashboard)
  })
</script>
