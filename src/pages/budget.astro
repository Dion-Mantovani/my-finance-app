---
import MainLayout from '../layouts/MainLayout.astro'
import EmptyState from '../components/shared/EmptyState.astro'
import BudgetCard from '../components/wallet/BudgetCard.astro'
---

<MainLayout title="My Wallets">
  <div class="mx-auto pb-[15vh]" x-data="budgetPage()">
    <header class="text-center mb-8">
      <h1 class="text-3xl font-extrabold text-[#1D1E20] font-jakarta">
        My Budgets
      </h1>
      <p class="text-slate-500 text-sm mt-1 leading-relaxed">
        Set your limits and stay on target.
      </p>

      <div class="flex items-center justify-center gap-6 mt-6">
        <button
          @click="prevMonth()"
          :disabled="isAtLimit()"
          :class="isAtLimit() ? 'opacity-20 cursor-not-allowed' : 'hover:text-indigo-600 active:scale-90'"
          class="w-10 h-10 rounded-full bg-white border border-slate-100 shadow-sm flex items-center justify-center text-slate-400 transition-all"
        >
          <i class="fa-solid fa-chevron-left text-xs"></i>
        </button>

        <div class="flex gap-1 items-center justify-center min-w-35">
          <div
            class="text-lg font-black text-[#1D1E20] uppercase tracking-tighter"
            x-text="monthNames[viewMonth]"
          >
          </div>
          <div class="inline-block px-2 py-0.5 bg-slate-100 rounded-md">
            <span
              class="text-lg font-black text-indigo-500 uppercase tracking-tighter"
              x-text="viewYear"
            >
            </span>
          </div>
        </div>

        <button
          @click="nextMonth()"
          :disabled="isCurrentMonth()"
          :class="isCurrentMonth() ? 'opacity-20 cursor-not-allowed' : 'hover:text-indigo-600 active:scale-90'"
          class="w-10 h-10 rounded-full bg-white border border-slate-100 shadow-sm flex items-center justify-center text-slate-400 transition-all"
        >
          <i class="fa-solid fa-chevron-right text-xs"></i>
        </button>
      </div>
    </header>

    <template x-if="budgets.length !== 0">
      <section
        class="mb-10 bg-[#1D1E20] rounded-[2.8rem] p-8 text-white shadow-2xl relative overflow-hidden"
      >
        <div
          class="absolute top-0 right-0 w-32 h-32 bg-indigo-500/20 blur-3xl rounded-full -mr-10 -mt-10"
        >
        </div>

        <div class="relative z-10">
          <div class="flex justify-between items-center">
            <p
              class="text-[10px] font-black uppercase tracking-[0.2em] text-indigo-300"
            >
              Master Monthly Budget
            </p>
            <template x-if="!isCurrentMonth()">
              <div
                class="px-3 py-1 bg-indigo-500/70 rounded-full backdrop-blur-md border border-white/30"
              >
                <span
                  class="text-[8px] flex justify-center items-center font-black uppercase tracking-[0.2em] text-white"
                  >Archive</span
                >
              </div>
            </template>
          </div>

          <div class="flex justify-between items-end mt-2 mb-6">
            <div>
              <h2 class="text-3xl font-black">
                Rp <span
                  x-text="Number(budgets.reduce((a, b) => a + (b.used || 0), 0)).toLocaleString('id-ID')"
                ></span>
              </h2>
              <p class="text-[10px] font-bold text-slate-400">
                Total Spent of Rp <span
                  x-text="Number(budgets.reduce((a, b) => a + b.limit, 0)).toLocaleString('id-ID')"
                ></span>
              </p>
            </div>
            <div class="text-right">
              <span
                class="text-2xl font-black text-indigo-400"
                x-text="Math.round((budgets.reduce((a, b) => a + b.used, 0) / budgets.reduce((a, b) => a + b.limit, 0)) * 100) + '%' || 0 + '%'"
              >
              </span>
            </div>
          </div>

          <div
            class="w-full h-4 bg-white/10 rounded-full overflow-hidden border border-white/5"
          >
            <div
              class="h-full bg-linear-to-r from-indigo-500 to-purple-500 transition-all duration-1000"
              :style="`width: ${(budgets.reduce((a, b) => a + b.used, 0) / budgets.reduce((a, b) => a + b.limit, 0)) * 100}%`"
            >
            </div>
          </div>
        </div>
      </section>
    </template>

    <section>
      <div x-cloak class="space-y-6">
        <template x-if="budgets.length > 0">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <template x-for="budget in budgets" :key="budget.id">
              <div
                @click="isCurrentMonth() ? editBudget(budget) : null"
                :class="!isCurrentMonth() ? 'cursor-default' : 'cursor-pointer active:scale-[0.98]'"
                class="transition-transform"
              >
                <BudgetCard />
              </div>
            </template>
            <template x-if="isCurrentMonth()">
              <button
                @click="isEditMode = false; isBudgetModalOpen = true"
                class="w-full py-12 border-2 border-dashed border-slate-200 rounded-[2.8rem] text-slate-400 flex flex-col items-center justify-center gap-3 hover:border-indigo-300 hover:text-indigo-400 transition-all bg-slate-50/50"
              >
                <div
                  class="w-14 h-14 rounded-full bg-white flex items-center justify-center shadow-sm"
                >
                  <i class="fa-solid fa-plus text-xl"></i>
                </div>
                <span class="text-xs font-bold uppercase tracking-widest"
                  >Set New Budget</span
                >
              </button>
            </template>
          </div>
        </template>
        <template x-if="budgets.length === 0">
          <div class="flex flex-col items-center -mt-10">
            <EmptyState
              title="No Budgets Set"
              message="You haven't set any monthly limits yet. Start budgeting to keep your expenses in check!"
              icon="fa-chart-pie"
              buttonText="Create First Budget"
              onClick="isBudgetModalOpen = true"
            />

            <template x-if="getLastAvailableBudget() && isCurrentMonth()">
              <div class="w-full px-6 mt-2">
                <div class="flex items-center gap-3 mb-4">
                  <div class="flex-1 h-px bg-slate-200"></div>
                  <span
                    class="text-[10px] font-bold text-slate-400 uppercase tracking-widest"
                    >Or</span
                  >
                  <div class="flex-1 h-px bg-slate-200"></div>
                </div>

                <button
                  @click="copyBudgets()"
                  class="w-full flex items-center justify-center gap-3 py-3 bg-white border-2 border-dashed border-slate-200 rounded-full text-slate-600 hover:border-indigo-300 hover:text-indigo-600 transition-all group"
                >
                  <i
                    class="fa-solid fa-copy text-sm group-hover:rotate-12 transition-transform"
                  ></i>
                  <span class="text-xs font-bold">
                    Copy from <span x-text="getLastAvailableBudget()?.monthName"
                    ></span>
                  </span>
                </button>
              </div>
            </template>
          </div>
        </template>
      </div>
    </section>

    <div
      x-show="isBudgetModalOpen"
      x-transition.opacity
      class="fixed inset-0 bg-[#1D1E20]/60 backdrop-blur-sm z-99 flex items-end sm:items-center justify-center p-4"
      x-cloak
    >
      <div
        @click.away="closeModal()"
        class="bg-white w-full max-w-lg rounded-[3rem] p-8 shadow-2xl relative max-h-[90vh] overflow-y-auto no-scrollbar"
      >
        <div class="flex justify-between items-center mb-8">
          <h2 class="text-2xl font-black text-[#1D1E20] font-jakarta">
            Set Budget
          </h2>
          <button @click="closeModal()" class="text-slate-400"
            ><i class="fa-solid fa-xmark text-2xl"></i></button
          >
        </div>

        <div class="space-y-6">
          <div>
            <label
              class="text-[10px] font-bold uppercase tracking-widest text-slate-400 mb-2 block"
              >Category</label
            >
            <select
              x-model="newBudget.category"
              class="w-full bg-slate-50 border-none rounded-2xl p-4 font-bold text-[#1D1E20] focus:ring-2 focus:ring-indigo-500"
            >
              <option value="">Select Category</option>
              <template x-for="cat in categoriesList" :key="cat.id">
                <option :value="cat.name" x-text="cat.name"></option>
              </template>
            </select>
          </div>
          <div>
            <label
              class="text-[10px] font-bold uppercase tracking-widest text-slate-400 mb-2 block"
              >Monthly Limit</label
            >
            <input
              x-model="newBudget.limit"
              type="number"
              class="w-full bg-slate-50 border-none rounded-2xl p-4 font-bold focus:ring-2 focus:ring-indigo-500"
              placeholder="Rp 1.000.000"
            />
          </div>

          <div class="mt-2 flex justify-center">
            <div
              class="inline-flex items-center gap-2 px-3 py-1 bg-amber-50 border border-amber-100 rounded-full"
            >
              <i class="fa-solid fa-circle-info text-[10px] text-amber-500"></i>
              <span
                class="text-[9px] font-bold text-amber-600 uppercase tracking-tight"
              >
                Data budget disimpan maksimal 1 tahun. Lebih dari itu data
                budget yang sudah tidak relevan akan terhapus otomatis.
              </span>
            </div>
          </div>

          <div class="mt-8 flex gap-3">
            <template x-if="isEditMode">
              <button
                @click="deleteBudget"
                class="flex-1 py-4 rounded-full font-bold text-sm bg-rose-50 text-rose-600 hover:bg-rose-100 transition-all"
              >
                <i class="fa-solid fa-trash-can mr-2"></i> Delete
              </button>
            </template>

            <button
              @click="saveBudget()"
              :disabled="!isCurrentMonth()"
              :class="!isCurrentMonth() ? 'opacity-50 grayscale cursor-not-allowed' : ''"
              class="w-full bg-[#1D1E20] text-white py-4 rounded-2xl font-bold uppercase"
            >
              <span x-text="isEditMode ? 'Update Budget' : 'Set Budget'"></span>
            </button>
          </div>
        </div>
      </div>
    </div>
  </div>
</MainLayout>

<script>
  import { storage } from '../utils/storage'

  document.addEventListener('alpine:init', () => {
    ;(window as any).budgetPage = () => ({
      showAmount: localStorage.getItem('DION_PRIVACY') !== 'false',
      budgets: [],
      categoriesList: [],
      isBudgetModalOpen: false,
      isEditMode: false,
      editId: null as string | null,
      viewMonth: new Date().getMonth(),
      viewYear: new Date().getFullYear(),
      monthNames: [
        'Januari',
        'Februari',
        'Maret',
        'April',
        'Mei',
        'Juni',
        'Juli',
        'Agustus',
        'September',
        'Oktober',
        'November',
        'Desember',
      ],

      newBudget: { category: '', limit: 0 },

      init() {
        // 1. Ambil settings dengan fallback array kosong agar .map() tidak error
        const settings = storage.getSettings() || {}
        const rawCategories = settings.categories || []

        // 2. Mapping categories ke object format
        this.categoriesList = rawCategories.map((catName: any, index: any) => ({
          id: index,
          name: catName,
        }))

        // 3. Jalankan refresh data lainnya
        this.refreshBudget()
        this.cleanupOldData()

        // 4. Listener untuk perubahan storage
        window.addEventListener('storage', (e) => {
          if (e.key === 'DION_SETTINGS' || e.key === 'DION_TRANSACTIONS') {
            const updatedSettings = storage.getSettings() || {}
            const updatedCats = updatedSettings.categories || []

            this.categoriesList = updatedCats.map(
              (catName: any, index: any) => ({
                id: index,
                name: catName,
              })
            )

            this.refreshBudget()
          }
        })
      },

      // Di dalam budgetPage()
      getLastAvailableBudget() {
        const settings = storage.getSettings() || {}
        const allBudgets = settings.budgets || []
        if (allBudgets.length === 0) return null

        let checkMonth = this.viewMonth
        let checkYear = this.viewYear

        // Mundur maksimal 12 bulan
        for (let i = 0; i < 12; i++) {
          checkMonth--
          if (checkMonth < 0) {
            checkMonth = 11
            checkYear--
          }

          const found = allBudgets.filter(
            (b: any) => b.month === checkMonth && b.year === checkYear
          )
          if (found.length > 0) {
            return {
              monthName: this.monthNames[checkMonth],
              month: checkMonth,
              year: checkYear,
              data: found,
            }
          }
        }
        return null
      },

      copyBudgets() {
        const lastBudget = this.getLastAvailableBudget()
        if (!lastBudget) return

        const settings = storage.getSettings() || {}

        // Clone data: ambil kategori & limit, set bulan & tahun ke view sekarang
        const newBudgets = lastBudget.data.map((b: any) => ({
          id: 'b-' + Date.now() + Math.random(), // ID baru
          category: b.category,
          limit: b.limit,
          month: this.viewMonth,
          year: this.viewYear,
          color: b.color || 'bg-indigo-600',
        }))

        settings.budgets.push(...newBudgets)
        storage.saveSettings(settings)
        this.refreshBudget()
      },

      cleanupOldData() {
        const settings = storage.getSettings() || {}
        if (!settings.budgets) return

        const now = new Date()
        const currentTotalMonths = now.getFullYear() * 12 + now.getMonth()

        settings.budgets = settings.budgets.filter((b: any) => {
          const budgetTotalMonths = b.year * 12 + b.month
          return currentTotalMonths - budgetTotalMonths < 12
        })

        storage.saveSettings(settings)
      },

      isAtLimit() {
        const now = new Date()
        const currentTotalMonths = now.getFullYear() * 12 + now.getMonth()
        const viewTotalMonths = this.viewYear * 12 + this.viewMonth

        // Jika selisihnya sudah 12 bulan, maka disable [cite: 93, 101]
        return currentTotalMonths - viewTotalMonths >= 12
      },

      // Logic Navigasi
      prevMonth() {
        if (this.isAtLimit()) return // Guard agar tidak lewat 12 bulan

        if (this.viewMonth === 0) {
          this.viewMonth = 11
          this.viewYear--
        } else {
          this.viewMonth--
        }
        this.refreshBudget()
      },

      nextMonth() {
        const now = new Date()
        if (this.isCurrentMonth()) return

        if (this.viewMonth === 11) {
          this.viewMonth = 0
          this.viewYear++
        } else {
          this.viewMonth++
        }
        this.refreshBudget()
      },

      isCurrentMonth() {
        const now = new Date()
        return (
          this.viewMonth === now.getMonth() &&
          this.viewYear === now.getFullYear()
        )
      },

      // Fungsi buat buka modal mode edit
      editBudget(budget: any) {
        this.isEditMode = true
        this.editId = budget.id
        this.newBudget = {
          category: budget.category,
          limit: budget.limit,
        }
        this.isBudgetModalOpen = true
      },

      // Fungsi buat reset saat tutup modal
      closeModal() {
        this.isBudgetModalOpen = false
        this.isEditMode = false
        this.editId = null
        this.newBudget = { category: '', limit: 0 }
      },

      // Di dalam budget.astro (Alpine.data)
      refreshBudget() {
        const settings = storage.getSettings() || {}
        const allBudgets = settings.budgets || []
        const transactions = storage.getTransactions() // Pakai storage.js

        // const now = new Date()
        // const currentMonth = now.getMonth()
        // const currentYear = now.getFullYear()

        // FILTER berdasarkan viewMonth & viewYear (Bukan new Date() lagi)
        const monthlyBudgets = allBudgets.filter(
          (b: any) => b.month === this.viewMonth && b.year === this.viewYear
        )

        // FILTER 1: Hanya ambil budget untuk bulan ini
        // const monthlyBudgets = allBudgets.filter(
        //   (b: any) => b.month === currentMonth && b.year === currentYear
        // )

        this.budgets = monthlyBudgets.map((b: any) => {
          // FILTER 2: Hitung transaksi expense yang cocok kategori & bulannya
          const used = transactions
            .filter(
              (t: any) => t.type === 'expense' && t.category === b.category
            )
            .filter((t: any) => {
              const d = new Date(t.date)
              //   return (
              //     d.getMonth() === currentMonth && d.getFullYear() === currentYear
              //   )
              // })
              return (
                d.getMonth() === this.viewMonth &&
                d.getFullYear() === this.viewYear
              )
            })
            .reduce((sum: number, t: any) => sum + Number(t.amount), 0)

          return {
            ...b,
            used,
            remaining: b.limit - used,
            percentage: (used / b.limit) * 100,
            isOver: used > b.limit,
          }
        })
      },

      saveBudget() {
        // PENGAMAN TAMBAHAN: Cek apakah user mencoba save di bulan selain sekarang
        if (!this.isCurrentMonth()) {
          alert('History mode is read-only. You cannot modify past budgets.')
          return
        }

        if (!this.newBudget.category || !this.newBudget.limit) {
          return alert('Lengkapi data!')
        }

        const settings = storage.getSettings()
        settings.budgets = settings.budgets || []

        if (this.isEditMode) {
          // Logic UPDATE
          const index = settings.budgets.findIndex(
            (b: any) => b.id === this.editId
          )
          if (index !== -1) {
            settings.budgets[index] = {
              ...settings.budgets[index],
              category: this.newBudget.category,
              limit: Number(this.newBudget.limit),
            }
          }
        } else {
          // Logic INSERT (yang sudah lo buat) [cite: 103]
          const now = new Date()
          const currentMonth = now.getMonth()
          const currentYear = now.getFullYear()

          // Cek duplikat hanya pas tambah baru [cite: 102]
          const isDuplicate = settings.budgets.some(
            (b: any) =>
              b.category === this.newBudget.category &&
              b.month === currentMonth &&
              b.year === currentYear
          )
          if (isDuplicate) return alert('Budget kategori ini sudah ada!')

          settings.budgets.push({
            id: 'b-' + Date.now(),
            category: this.newBudget.category,
            limit: Number(this.newBudget.limit),
            month: currentMonth,
            year: currentYear,
            color: 'bg-indigo-600',
          })
        }

        storage.saveSettings(settings)
        this.closeModal()
        this.refreshBudget()
      },
      // saveBudget() {
      //   if (!this.newBudget.category || !this.newBudget.limit) {
      //     return alert('Lengkapi data!')
      //   }

      //   const settings = storage.getSettings()
      //   settings.budgets = settings.budgets || []

      //   // Ambil waktu sekarang untuk stempel periode
      //   const now = new Date()
      //   const currentMonth = now.getMonth() // 0-11
      //   const currentYear = now.getFullYear()

      //   // Cek apakah kategori ini sudah punya budget di bulan yang sama
      //   const isDuplicate = settings.budgets.some(
      //     (b: any) =>
      //       b.category === this.newBudget.category &&
      //       b.month === currentMonth &&
      //       b.year === currentYear
      //   )

      //   if (isDuplicate) {
      //     return alert('Budget untuk kategori ini sudah ada di bulan ini!')
      //   }

      //   // Simpan dengan struktur data baru
      //   settings.budgets.push({
      //     id: 'b-' + Date.now(), // ID Unik
      //     category: this.newBudget.category,
      //     limit: Number(this.newBudget.limit),
      //     month: currentMonth, // Penambahan Periode Bulan
      //     year: currentYear, // Penambahan Periode Tahun
      //     color: 'bg-indigo-600',
      //   })

      //   storage.saveSettings(settings)
      //   this.isBudgetModalOpen = false
      //   this.newBudget = { category: '', limit: 0 }
      //   this.refreshBudget()
      // },

      deleteBudget() {
        if (!confirm('Yakin mau hapus budget ini?')) return

        const settings = storage.getSettings()
        settings.budgets = settings.budgets.filter(
          (b: any) => b.id !== this.editId
        )

        storage.saveSettings(settings)
        this.closeModal()
        this.refreshBudget()
      },
    })
  })
</script>

<style>
  [x-cloak] {
    display: none !important;
  }
  .no-scrollbar::-webkit-scrollbar {
    display: none;
  }
  .no-scrollbar {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
</style>
