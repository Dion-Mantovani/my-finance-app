---
import MainLayout from '../layouts/MainLayout.astro'
import TransactionItem from '../components/shared/TransactionItem.astro'
import EmptyState from '../components/shared/EmptyState.astro'
import Filter from '../components/expense/Filter.astro'
---

<MainLayout title="All History">
  <div class="relative mx-auto pb-[15vh]" x-data="expensePage()">
    <div
      class="bg-app-bg fixed top-0 right-1/2 z-50 w-full translate-x-1/2 px-4 pt-4"
    >
      <!-- SEARCH -->
      <div class="mb-3">
        <div class="relative">
          <i
            class="fa-solid fa-magnifying-glass absolute top-1/2 left-4 -translate-y-1/2 text-xs text-slate-300"
          ></i>
          <input
            type="text"
            x-model="searchQuery"
            @input.debounce.300ms="refreshAll()"
            :placeholder="isFilterActive() ? 'Cari di hasil filter...' : 'Cari transaksi...'"
            class="w-full rounded-2xl border border-slate-100 bg-white p-3 pl-11 text-xs font-bold shadow-sm transition-all outline-none focus:border-indigo-500"
          />
        </div>
      </div>

      <!-- FILTER -->
      <section class="mb-3">
        <div class="flex items-center gap-2">
          <div
            class="flex grow items-center justify-between gap-3 overflow-hidden rounded-2xl bg-slate-100 p-2"
          >
            <button
              @click="changeDate(-1)"
              class="flex h-9 w-9 items-center justify-center rounded-xl border border-slate-100 bg-white text-slate-400 shadow-sm transition-all active:scale-90"
            >
              <i class="fa-solid fa-chevron-left text-sm"></i>
            </button>

            <div class="flex flex-col items-center">
              <span
                class="mb-1 text-center text-[8px] font-black tracking-[0.2em] text-indigo-500 uppercase"
                >Periode</span
              >
              <div class="relative">
                <input
                  type="date"
                  x-model="selectedDate"
                  @change="startDate = ''; endDate = ''; refreshAll()"
                  class="absolute inset-0 cursor-pointer opacity-0"
                />
                <div class="text-xs font-bold text-slate-700">
                  <span class="whitespace-nowrap" x-text="getDateLabel()"
                  ></span>
                  <i class="fa-solid fa-calendar-days ml-2"></i>
                </div>
              </div>
            </div>

            <button
              @click="changeDate(1)"
              class="flex h-9 w-9 items-center justify-center rounded-xl border border-slate-100 bg-white text-slate-400 shadow-sm transition-all active:scale-90"
            >
              <i class="fa-solid fa-chevron-right text-sm"></i>
            </button>
          </div>

          <div class="flex flex-none items-center gap-2">
            <button
              class="flex h-11 w-11 items-center justify-center rounded-2xl border border-slate-100 bg-white text-slate-400 shadow-sm transition-all active:scale-100"
            >
              <i class="fa-solid fa-file-export text-sm"></i>
            </button>

            <button
              @click="showFilterModal = true"
              class="relative h-11 w-11 rounded-2xl bg-indigo-600 text-white shadow-sm transition-all active:scale-90"
            >
              <i class="fa-solid fa-filter text-sm"></i>

              <template x-if="isFilterActive()">
                <span
                  class="absolute -top-1 -right-1 h-3 w-3 rounded-full border-2 border-white bg-red-500"
                ></span>
              </template>
            </button>
          </div>
        </div>
      </section>

      <!-- BALANCE CARD -->
      <section class="mb-3">
        <div
          class="relative flex items-center justify-between overflow-hidden rounded-2xl bg-indigo-600 p-6 shadow-md shadow-indigo-100"
        >
          <div
            class="absolute -top-4 -right-4 h-24 w-24 rounded-full bg-white/10 blur-2xl"
          >
          </div>

          <div class="flex-1 text-center">
            <p
              class="mb-1 text-[9px] font-bold tracking-widest text-indigo-200 uppercase"
            >
              Pemasukan
            </p>
            <p
              x-show="$store.app.showAmount"
              class="text-xs font-black text-white"
              x-text="'Rp' + summary.income.toLocaleString()"
            >
              0
            </p>
            <span class="text-white" x-show="!$store.app.showAmount" x-cloak
              >•••</span
            >
          </div>

          <div class="h-8 w-px bg-indigo-500/50"></div>

          <div class="flex-1 text-center">
            <p
              class="mb-1 text-[9px] font-bold tracking-widest text-indigo-200 uppercase"
            >
              Pengeluaran
            </p>
            <p
              x-show="$store.app.showAmount"
              class="text-xs font-black text-white"
              x-text="'Rp' + summary.expense.toLocaleString()"
            >
              0
            </p>
            <span class="text-white" x-show="!$store.app.showAmount" x-cloak
              >•••</span
            >
          </div>

          <div class="h-8 w-px bg-indigo-500/50"></div>

          <div class="flex-1 text-center">
            <p
              class="mb-1 text-[9px] font-bold tracking-widest text-indigo-200 uppercase"
            >
              Balance
            </p>
            <p
              x-show="$store.app.showAmount"
              class="text-xs font-black text-white"
              x-text="'Rp' + summary.balance.toLocaleString()"
            >
              0
            </p>
            <span class="text-white" x-show="!$store.app.showAmount" x-cloak
              >•••</span
            >
          </div>
        </div>
      </section>
    </div>

    <!-- TRANSACTIONS LIST -->
    <section class="mt-50">
      <template x-if="Object.keys(groupedTransactions).length > 0">
        <div>
          <template x-if="Object.keys(groupedTransactions).length > 0">
            <div class="space-y-2">
              <template
                x-for="(date, index) in Object.keys(groupedTransactions)"
                :key="date"
              >
                <div
                  class="py-4 transition-all"
                  :class="startDate && endDate && index !== 0 ? 'border-t border-indigo-200 mt-4 pt-8' : ''"
                >
                  <div
                    x-show="startDate && endDate"
                    class="mb-6 flex items-center justify-between px-2"
                  >
                    <span
                      class="text-[10px] font-black tracking-[0.2em] text-indigo-500 uppercase"
                      x-text="storage.formatDateTitle(date)"></span>

                    <div
                      class="flex items-center gap-2 rounded-full border border-indigo-200 bg-slate-50 px-3 py-1"
                    >
                      <span
                        x-show="$store.app.showAmount"
                        class="text-xs font-black text-slate-700"
                        x-text="'Rp' + (groupedTransactions[date].totalDaily || 0).toLocaleString('id-ID')"
                      ></span>
                      <span x-show="!$store.app.showAmount" x-cloak>•••</span>
                    </div>
                  </div>

                  <div class="space-y-2">
                    <template
                      x-for="item in groupedTransactions[date].items"
                      :key="item.id"
                    >
                      <div class="relative">
                        <TransactionItem />
                      </div>
                    </template>
                  </div>
                </div>
              </template>
            </div>
          </template>
        </div>
      </template>

      <template x-if="Object.keys(groupedTransactions).length === 0">
        <EmptyState
          title="No History Found"
          message="We couldn't find any transactions. Try adjusting your filters or add a new record."
          buttonText="Record Transaction"
          icon="fa-clock-rotate-left"
          type="link"
          link="/transactions"
        />
      </template>
    </section>

    <!-- FILTER MODAL -->
    <div
      x-show="showFilterModal"
      x-cloak
      class="fixed inset-0 z-60 flex items-end justify-center"
    >
      <div
        class="absolute inset-0 bg-slate-900/40 backdrop-blur-sm"
        @click="showFilterModal = false"
      >
      </div>
      <div
        class="animate-slide-up relative w-full rounded-t-4xl bg-white p-8 shadow-2xl"
      >
        <div class="mx-auto mb-8 h-1.5 w-12 rounded-full bg-slate-100"></div>

        <div class="no-scrollbar max-h-[80vh] space-y-8 overflow-y-auto pb-10">
          <div>
            <label
              class="mb-3 block text-[10px] font-black tracking-widest text-slate-400 uppercase"
              >Custom Range</label
            >
            <div class="grid grid-cols-2 gap-3">
              <input
                type="date"
                x-model="startDate"
                class="rounded-xl border-none bg-slate-50 p-3 text-xs font-bold outline-none"
              />
              <input
                type="date"
                x-model="endDate"
                class="rounded-xl border-none bg-slate-50 p-3 text-xs font-bold outline-none"
              />
            </div>
          </div>

          <div>
            <label
              class="mb-3 block text-[10px] font-black tracking-widest text-slate-400 uppercase"
              >Tipe Transaksi</label
            >
            <div class="no-scrollbar flex gap-2 overflow-x-auto pb-2">
              <template
                x-for="type in ['all', 'expense', 'income', 'transfer']"
              >
                <button
                  @click="filterType = type"
                  :class="filterType === type ? 'bg-indigo-600 text-white' : 'bg-slate-50 text-slate-500'"
                  class="rounded-xl px-4 py-2 text-[10px] font-bold tracking-widest uppercase transition-all"
                  x-text="type"></button>
              </template>
            </div>
          </div>

          <div>
            <label
              class="mb-3 block text-[10px] font-black tracking-widest text-slate-400 uppercase"
              >Pilih Rekening</label
            >
            <div class="no-scrollbar flex gap-2 overflow-x-auto pb-2">
              <button
                @click="filterWallet = 'all'; refreshAll()"
                :class="filterWallet === 'all' ? 'bg-indigo-600 text-white' : 'bg-slate-50 text-slate-500'"
                class="shrink-0 rounded-xl px-4 py-2 text-[10px] font-bold uppercase transition-all"
                >All</button
              >
              <template x-for="w in wallets" :key="w.id">
                <button
                  @click="filterWallet = String(w.id); refreshAll()"
                  :class="filterWallet === w.id ? 'bg-indigo-600 text-white' : 'bg-slate-50 text-slate-500'"
                  class="shrink-0 rounded-xl px-4 py-2 text-[10px] font-bold uppercase transition-all"
                  x-text="w.name"></button>
              </template>
            </div>
          </div>

          <div>
            <label
              class="mb-3 block text-[10px] font-black tracking-widest text-slate-400 uppercase"
            >
              Berdasarkan Kategori
            </label>
            <div class="flex flex-wrap gap-2">
              <div class="flex flex-wrap gap-2">
                <button
                  @click="filterCategory = 'all'"
                  :class="filterCategory === 'all' ? 'bg-indigo-600 text-white' : 'bg-slate-50 text-slate-500'"
                  class="rounded-xl px-4 py-2 text-[9px] font-bold tracking-widest uppercase transition-all"
                >
                  All
                </button>

                <template x-for="(cat, index) in categories" :key="index">
                  <button
                    @click="filterCategory = (typeof cat === 'object' ? cat.name : cat)"
                    :class="filterCategory === (typeof cat === 'object' ? cat.name : cat) ? 'bg-indigo-600 text-white' : 'bg-slate-50 text-slate-500'"
                    class="rounded-xl px-4 py-2 text-[9px] font-bold tracking-widest uppercase transition-all"
                  >
                    <span x-text="typeof cat === 'object' ? cat.name : cat"
                    ></span>
                  </button>
                </template>
              </div>
            </div>
          </div>

          <div class="grid grid-cols-3 gap-3">
            <button
              @click="resetFilter()"
              class="col-span-1 rounded-2xl bg-slate-100 py-4 text-[10px] font-black text-slate-500 uppercase"
              >Reset</button
            >
            <button
              @click="applyFilter()"
              class="col-span-2 rounded-2xl bg-indigo-600 py-4 text-[10px] font-black text-white uppercase shadow-xl shadow-indigo-100 transition-all active:scale-95"
              >Terapkan</button
            >
          </div>
        </div>
      </div>
    </div>
  </div>
</MainLayout>

<script>
  import Alpine from 'alpinejs'
  import { expensePage } from '../logic/expense'

  // Daftarkan ke Alpine
  document.addEventListener('alpine:init', () => {
    Alpine.data('expensePage', expensePage)
  })
</script>
