    <!-- 📍 NEW : Top Spending with information -->
    <section class="mb-10" x-data="{ showAll: false }">
      <div class="mb-3 flex items-end justify-between px-1 select-none">
        <div>
          <h3
            class="font-jakarta text-lg font-black tracking-wide text-[#1D1E20] capitalize"
          >
            Spending by Category
          </h3>
          <p class="mt-1 text-xs font-medium text-slate-400">
            Rincian pengeluaran tertinggi ke terendah
          </p>
        </div>

        <span
          class="rounded-full border border-slate-100 bg-slate-50 px-2.5 py-1 text-[10px] font-black tracking-wide text-slate-500"
          x-text="topCategories.length + ' Kategori'"
        >
          0 Kategori
        </span>
      </div>

      <div class="divide-y divide-slate-50 border-b border-slate-50">
        <template
          x-for="(cat, index) in topCategories.slice(0, 3)"
          :key="'base-'+cat.name"
        >
          <div class="group px-1 py-3 transition-colors duration-200">
            <div class="mb-3.5 flex items-center justify-between gap-4">
              <div class="flex max-w-[75%] items-center gap-4">
                <div
                  class="flex h-12 w-12 shrink-0 items-center justify-center rounded-2xl text-white shadow-sm transition-transform group-hover:scale-105"
                  :class="cat.color"
                >
                  <i class="fa-solid text-base" :class="cat.icon"></i>
                </div>

                <div class="truncate select-none">
                  <h4
                    class="text-sm font-black tracking-tight text-[#1D1E20]"
                    x-text="cat.name"
                  >
                    Nama Kategori
                  </h4>

                  <div
                    class="mt-1 flex items-center gap-1.5 truncate text-[10px] font-medium tracking-wide text-slate-400"
                  >
                    <span
                      class="font-bold text-indigo-600/90"
                      x-text="Math.round(cat.percentage) + '% total'"></span>
                    <span class="text-slate-200">|</span>
                    <span x-text="(cat.transactionCount || '0') + 'x Act'"
                    ></span>
                    <span class="text-slate-200">|</span>
                    <span
                      x-text="'Avg: Rp ' + Number(cat.averageAmount || (cat.amount / (cat.transactionCount || 1))).toLocaleString('id-ID')"
                    ></span>
                  </div>
                </div>
              </div>

              <div
                class="flex shrink-0 flex-col items-end justify-center text-right"
              >
                <p
                  x-show="$store.app.showAmount"
                  class="text-sm font-black tracking-tight text-[#1D1E20]"
                  x-text="'Rp ' + Number(cat.amount).toLocaleString('id-ID')"
                >
                  Rp 0
                </p>
                <span
                  class="font-jakarta text-sm font-black tracking-widest text-slate-300"
                  x-show="!$store.app.showAmount"
                  x-cloak>••••••</span
                >

                <div
                  class="mt-0.5 flex items-center justify-end gap-1 select-none"
                >
                  <i
                    class="fa-solid text-[10px]"
                    x-show="cat.trendText !== 'Baru periode ini'"
                    :class="cat.trend === 'up' ? 'fa-arrow-trend-up text-rose-500' : 'fa-arrow-trend-down text-emerald-500'"
                  ></i>
                  <span
                    class="text-[10px] font-bold tracking-tight capitalize"
                    :class=`{
                  'text-rose-500': cat.trend === 'up' && cat.trendText !== 'Baru periode ini',
                  'text-emerald-500': cat.trend === 'down' && cat.trendText !== 'Baru periode ini',
                  'text-slate-400': cat.trendText === 'Baru periode ini'
                }`
                    x-text="cat.trendText"
                  >
                    Normal
                  </span>
                </div>
              </div>
            </div>

            <div
              class="h-1.5 w-full overflow-hidden rounded-full bg-slate-100 select-none"
            >
              <div
                class="h-full rounded-full shadow-xs transition-all duration-1000 ease-out"
                :class="cat.color"
                :style="`width: ${Math.min(cat.percentage, 100)}%`"
              >
              </div>
            </div>
          </div>
        </template>

        <template
          x-for="(cat, index) in topCategories.slice(3)"
          :key="'ext-'+cat.name"
