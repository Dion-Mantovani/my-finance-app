---
import MainLayout from '../layouts/MainLayout.astro'
import TransactionHeader from '../components/transaction/TransactionHeader.astro'
import TypeToggle from '../components/transaction/TypeToggle.astro'
import AmountDisplay from '../components/transaction/AmountDisplay.astro'
import CustomSelect from '../components/transaction/CustomSelect.astro'
import EmptyState from '../components/shared/EmptyState.astro'
---

<MainLayout title="Add Transaction">
  <main
    class="mx-auto flex h-auto w-full flex-col bg-white"
    x-data="transactionForm()"
    x-init="init($nextTick)"
  >
    <TransactionHeader />
    <TypeToggle />
    <AmountDisplay />

    <section class="flex-1 space-y-4 rounded-t-[2.5rem] bg-slate-50 px-6 py-2">
      <div>
        <label
          class="mb-1 ml-1 block text-[10px] font-bold tracking-widest text-slate-400 uppercase"
          >Date</label
        >
        <input
          required
          type="date"
          x-model="date"
          tabindex="-1"
          class="w-full rounded-xl border border-slate-100 bg-white p-3 text-[12px] font-bold shadow-sm outline-none focus:border-indigo-500"
        />
      </div>

      <div
        class="grid gap-4"
        :class="type === 'transfer' ? 'grid-cols-2' : 'grid-cols-1'"
      >
        <div class="relative">
          <label
            class="mb-1 ml-1 block text-[10px] font-bold tracking-widest text-slate-400 uppercase"
            >From Wallet</label
          >
          <button
            @click="openWallet = !openWallet"
            type="button"
            class="flex w-full items-center justify-between rounded-xl border border-slate-100 bg-white p-2.5 text-[12px] font-bold text-slate-600 shadow-sm transition-all outline-none focus:border-indigo-500"
          >
            <span x-text="walletSource || 'Select'"></span>
            <i
              class="fa-solid fa-chevron-down text-[10px] transition-transform"
              :class="openWallet ? 'rotate-180 text-indigo-500' : 'text-slate-300'"
            ></i>
          </button>

          <div
            x-show="openWallet"
            @click.away="openWallet = false"
            class="absolute z-50 mt-2 w-full overflow-hidden rounded-2xl border border-slate-100 bg-white shadow-xl"
            x-cloak
          >
            <template x-for="w in wallets" :key="w.id">
              <div
                @click="walletSourceId = w.id; walletSource = w.name; openWallet = false"
                class="cursor-pointer border-b border-slate-50 p-3 text-[12px] font-bold text-slate-600 last:border-none hover:bg-slate-50"
              >
                <span x-text="w.name"></span>
              </div>
            </template>
          </div>
        </div>
        <div class="relative" x-show="type === 'transfer'" x-cloak>
          <label
            class="mb-1 ml-1 block text-[10px] font-bold tracking-widest text-slate-400 uppercase"
            >To Wallet</label
          >
          <button
            @click="openDest = !openDest"
            type="button"
            class="flex w-full items-center justify-between rounded-xl border border-slate-100 bg-white p-2.5 text-[12px] font-bold text-slate-600 shadow-sm transition-all outline-none focus:border-indigo-500"
          >
            <span x-text="walletDest || 'Select'"></span>
            <i
              class="fa-solid fa-chevron-down text-[10px] transition-transform"
              :class="openDest ? 'rotate-180 text-indigo-500' : 'text-slate-300'"
            ></i>
          </button>

          <div
            x-show="openDest"
            @click.away="openDest = false"
            class="absolute z-50 mt-2 w-full overflow-hidden rounded-2xl border border-slate-100 bg-white shadow-xl"
          >
            <template x-for="w in wallets" :key="w.id">
              <div
                @click="walletDestId = w.id; walletDest = w.name; openDest = false"
                class="flex cursor-pointer items-center justify-between border-b border-slate-50 p-3 text-[12px] font-bold text-slate-600 last:border-none hover:bg-slate-50"
                :class="w.id === walletSourceId ? 'opacity-30 pointer-events-none bg-slate-50' : ''"
              >
                <span x-text="w.name"></span>
                <template x-if="w.id === walletSourceId">
                  <span class="text-[8px] text-slate-400 uppercase"
                    >Same Wallet</span
                  >
                </template>
              </div>
            </template>
          </div>
        </div>
      </div>

      <div>
        <label
          class="mb-1 ml-1 block text-[10px] font-bold tracking-widest text-slate-400 uppercase"
          >Notes</label
        >
        <input
          required
          x-ref="noteInput"
          x-model="notes"
          @input.debounce.500ms="predictCategory()"
          @keydown.enter.prevent="saveRecord()"
          type="text"
          placeholder="Beli bensin..."
          class="w-full rounded-xl border border-slate-100 bg-white p-3 text-[12px] font-bold shadow-sm outline-none focus:border-indigo-500"
        />
      </div>

      <CustomSelect
        x-show="type !== 'transfer'"
        label="Category"
        xModel="category"
        placeholder="Select"
        options="categories"
        openState="openCategory"
        mode="cat"
        xRef="catBtn"
      />

      <div class="mt-5 flex gap-3 space-y-3">
        <button
          @click="saveRecord()"
          type="button"
          class="order-2 h-12 w-full rounded-2xl bg-indigo-600 text-sm font-bold text-white shadow-lg shadow-indigo-100 transition-all active:scale-[0.98]"
        >
          <span x-text="isEditMode ? 'Update Transaction' : 'Save Transaction'"
          ></span>
        </button>

        <template x-if="isEditMode">
          <button
            @click="confirmDelete()"
            type="button"
            class="order-1 flex h-12 w-full items-center justify-center gap-2 rounded-2xl border border-rose-100 bg-rose-50 text-xs font-bold text-rose-500 transition-all active:bg-rose-100"
          >
            <i class="fa-solid fa-trash-can text-sm"></i>
            <span>Delete Transaction</span>
          </button>
        </template>
      </div>
    </section>

    <div
      x-show="showWalletModal"
      x-cloak
      class="fixed inset-0 z-60 flex items-end justify-center"
    >
      <div
        class="absolute inset-0 bg-slate-900/40 backdrop-blur-sm"
        @click="showWalletModal = false"
      >
      </div>
      <div class="relative w-full rounded-t-[3rem] bg-white p-8 shadow-2xl">
        <h3
          class="mb-6 text-center text-[10px] font-black tracking-[0.2em] text-indigo-500 uppercase"
          x-text="modalStep === 'source' ? 'Pilih Rekening Asal' : 'Pilih Rekening Tujuan'"
        >
        </h3>

        <div class="grid grid-cols-1 gap-3">
          <template x-if="wallets.length > 0">
            <template x-for="w in wallets">
              <button
                @click="selectWalletInitial(w, { $nextTick, $refs })"
                :disabled="modalStep === 'dest' && w.name === walletSource"
                :class="modalStep === 'dest' && w.name === walletSource ? 'opacity-30' : 'hover:bg-indigo-50'"
                class="flex items-center justify-between rounded-2xl border border-slate-100 p-5 transition-all"
              >
                <span class="font-bold text-slate-700" x-text="w.name"></span>
                <i class="fa-solid fa-chevron-right text-[10px] text-slate-300"
                ></i>
              </button>
            </template>
          </template>

          <template x-if="wallets.length === 0">
            <EmptyState
              title="No Wallets Yet"
              message="You don't have any wallets connected. Create one to start tracking your balances and transactions."
              icon="fa-building-columns"
              buttonText="Create Wallet in Wallets Page"
              type="link"
              link="/wallets"
            />
          </template>
        </div>
      </div>
    </div>
  </main>
</MainLayout>

<script>
  import Alpine from 'alpinejs'
  import { transactionForm } from '../logic/transactions'

  // Daftarkan ke Alpine
  document.addEventListener('alpine:init', () => {
    Alpine.data('transactionForm', transactionForm)
  })
</script>
