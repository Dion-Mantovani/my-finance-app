---
import MainLayout from '../layouts/MainLayout.astro'
import EmptyState from '../components/shared/EmptyState.astro'
import WalletCard from '../components/wallet/WalletCard.astro'
---

<MainLayout title="My Wallets">
  <div class="mx-auto pb-[15vh]" x-data="walletPage()">
    <header class="text-center mb-8">
      <h1 class="text-3xl font-extrabold text-[#1D1E20] font-jakarta">
        My Wallets
      </h1>
      <p class="text-slate-500 text-sm mt-1 leading-relaxed">
        Manage your sources and set your limits.
      </p>
    </header>

    <section>
      <div x-cloak class="space-y-6">
        <template x-if="wallets.length > 0">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <template x-for="wallet in wallets" :key="wallet.id">
              <div @click="openEditModal(wallet)">
                <WalletCard />
              </div>
            </template>
            <button
              @click="openAddModal()"
              class="w-full py-12 border-2 border-dashed border-slate-200 rounded-[2.8rem] text-slate-400 flex flex-col items-center justify-center gap-3 hover:border-indigo-300 hover:text-indigo-400 transition-all bg-slate-50/50"
            >
              <div
                class="w-14 h-14 rounded-full bg-white flex items-center justify-center shadow-sm"
              >
                <i class="fa-solid fa-plus text-xl"></i>
              </div>
              <span class="text-xs font-bold uppercase tracking-widest"
                >Add New Wallet</span
              >
            </button>
          </div>
        </template>
        <template x-if="wallets.length === 0">
          <EmptyState
            title="No Wallets Yet"
            message="You don't have any wallets connected. Create one to start tracking your balances and transactions."
            icon="fa-building-columns"
            buttonText="Create First Wallet"
            type="button"
            onClick="openAddModal()"
          />
        </template>
      </div>
    </section>

    <div
      x-show="isModalOpen"
      x-transition.opacity
      class="fixed inset-0 bg-[#1D1E20]/60 backdrop-blur-sm z-99 flex items-end sm:items-center justify-center p-4"
      x-cloak
    >
      <div
        @click.away="closeModal()"
        x-show="isModalOpen"
        x-transition:enter="transition ease-out duration-300"
        x-transition:enter-start="opacity-0 translate-y-8 sm:scale-95"
        x-transition:enter-end="opacity-100 translate-y-0 sm:scale-100"
        class="bg-white w-full max-w-lg rounded-[3rem] p-8 shadow-2xl relative max-h-[90vh] overflow-y-auto no-scrollbar"
      >
        <div class="flex justify-between items-center mb-8">
          <h2 class="text-2xl font-black text-[#1D1E20] font-jakarta">
            New Wallet
          </h2>
          <button
            @click="isModalOpen = false"
            class="text-slate-400 hover:text-rose-500 transition-colors"
          >
            <i class="fa-solid fa-xmark text-2xl"></i>
          </button>
        </div>

        <div class="space-y-6">
          <div>
            <label
              class="text-[10px] font-bold uppercase tracking-widest text-slate-400 mb-2 block"
              >Name</label
            >
            <input
              x-model="newWallet.name"
              type="text"
              class="w-full bg-slate-50 border-none rounded-2xl p-4 focus:ring-2 focus:ring-indigo-500 font-bold"
              placeholder="e.g. Bank Mandiri"
            />
          </div>

          <div>
            <label
              class="text-[10px] font-bold uppercase tracking-widest text-slate-400 mb-2 block"
              >Initial Balance</label
            >
            <input
              x-model="newWallet.balance"
              type="number"
              placeholder="0"
              class="w-full bg-slate-50 border-none rounded-2xl p-4 focus:ring-2 focus:ring-indigo-500 font-bold"
            />
          </div>

          <div>
            <label
              class="text-[10px] font-bold uppercase tracking-widest text-slate-400 mb-2 block"
              >Select Icon</label
            >
            <div class="grid grid-cols-4 gap-3">
              <template x-for="ico in icons">
                <button
                  @click="newWallet.icon = ico.val"
                  class="p-4 rounded-2xl border-2 transition-all flex items-center justify-center"
                  :class="newWallet.icon === ico.val ? 'border-indigo-500 bg-indigo-50 text-indigo-600' : 'border-slate-50 text-slate-400 hover:bg-slate-50'"
                >
                  <i class="fa-solid text-xl" :class="ico.val"></i>
                </button>
              </template>
            </div>
          </div>

          <div>
            <label
              class="text-[10px] font-bold uppercase tracking-widest text-slate-400 mb-2 block"
              >Theme Color</label
            >
            <div class="flex flex-wrap gap-3">
              <template x-for="color in colors">
                <button
                  @click="selectColor(color.name)"
                  class="w-10 h-10 rounded-full border-4 transition-all shadow-sm"
                  :class="[color.bg, newWallet.colorName === color.name ? 'border-white scale-110 shadow-lg ring-2 ring-slate-100' : 'border-transparent opacity-70 hover:opacity-100']"
                ></button>
              </template>
            </div>
          </div>

          <div class="mt-8 flex gap-3">
            <template x-if="isEditMode">
              <button
                @click="deleteWallet"
                class="flex-1 py-4 rounded-full font-bold text-sm bg-rose-50 text-rose-600 hover:bg-rose-100 transition-all"
              >
                <i class="fa-solid fa-trash-can mr-2"></i> Delete
              </button>
            </template>

            <button
              @click="saveWallet()"
              class="flex-2 bg-indigo-600 text-white py-4 rounded-full font-bold text-sm transition-all shadow-lg"
            >
              <span x-text="isEditMode ? 'Update Wallet' : 'Create Wallet'"
              ></span>
            </button>
          </div>

          <template x-if="isEditMode && transactionCount > 0">
            <p class="text-[10px] text-center text-slate-400 mt-4 italic">
              * Wallet cannot be deleted. You have <span
                class="text-rose-500 font-bold"
                x-text="transactionCount"></span> transactions linked.
            </p>
          </template>
        </div>
      </div>
    </div>
  </div>
</MainLayout>

<script>
  import { storage } from '../utils/storage'

  document.addEventListener('alpine:init', () => {
    ;(window as any).walletPage = () => ({
      showAmount: localStorage.getItem('DION_PRIVACY') !== 'false',
      wallets: [] as any[], // Memberitahu TS bahwa ini array yang akan berisi objek
      isModalOpen: false,
      isEditMode: false,
      editId: null,
      transactionCount: 0,

      newWallet: {
        name: '',
        balance: 0,
        icon: 'fa-wallet',
        colorName: 'blue',
        gradient: 'from-blue-400 to-blue-700',
      },

      icons: [
        { name: 'Wallet', val: 'fa-wallet' },
        { name: 'Bank', val: 'fa-building-columns' },
        { name: 'Cash', val: 'fa-money-bill-wave' },
        { name: 'Savings', val: 'fa-piggy-bank' },
        { name: 'Investment', val: 'fa-chart-line' },
        { name: 'Card', val: 'fa-credit-card' },
        { name: 'Gold', val: 'fa-coins' },
        { name: 'Phone', val: 'fa-mobile-screen-button' },
      ],

      colors: [
        { name: 'blue', bg: 'bg-blue-500' },
        { name: 'green', bg: 'bg-green-500' },
        { name: 'rose', bg: 'bg-rose-500' },
        { name: 'amber', bg: 'bg-amber-500' },
        { name: 'indigo', bg: 'bg-indigo-500' },
        { name: 'violet', bg: 'bg-violet-500' },
        { name: 'cyan', bg: 'bg-cyan-500' },
        { name: 'slate', bg: 'bg-slate-500' },
      ],

      init() {
        this.refreshWallets()

        window.addEventListener('storage', (e) => {
          if (e.key === 'DION_SETTINGS' || e.key === 'DION_TRANSACTIONS') {
            this.refreshWallets()
          }
        })
      },

      selectColor(name: string) {
        this.newWallet.colorName = name
        this.newWallet.gradient = `from-${name}-400 to-${name}-700`
      },

      // Fungsi buat buka modal mode Tambah
      openAddModal() {
        this.isEditMode = false
        this.editId = null
        this.newWallet = {
          name: '',
          balance: 0,
          icon: 'fa-wallet',
          colorName: 'blue',
          gradient: 'from-blue-400 to-blue-700',
        }
        this.isModalOpen = true
      },

      // Fungsi buat buka modal mode Detail/Edit
      openEditModal(wallet: any) {
        this.isEditMode = true
        this.editId = wallet.id

        // Isi form dengan data wallet yang diklik
        this.newWallet = {
          name: wallet.name,
          balance: wallet.currentBalance, // Kita tampilkan saldo saat ini
          icon: wallet.icon,
          colorName: wallet.colorName,
          gradient: wallet.gradient,
        }

        // Cek jumlah transaksi buat Guard Delete nanti
        const allTransactions = storage.getTransactions()
        this.transactionCount = allTransactions.filter(
          (t: any) => t.walletId === wallet.id || t.walletIdDest === wallet.id
        ).length

        this.isModalOpen = true
      },

      saveWallet() {
        if (!this.newWallet.name) {
          alert('Nama wallet wajib diisi!')
          return
        }

        const settings = storage.getSettings()
        settings.wallets = settings.wallets || []
        const now = new Date().toISOString().split('T')[0]

        if (this.isEditMode) {
          // --- MODE EDIT & KOREKSI SALDO ---
          const index = settings.wallets.findIndex(
            (w: any) => w.id === this.editId
          )

          if (index !== -1) {
            const oldWallet = settings.wallets[index]

            // Ambil saldo sistem saat ini (sebelum diupdate)
            const targetWallet = this.wallets.find(
              (w: any) => w.id === this.editId
            )
            // Gunakan optional chaining (?.) untuk jaga-jaga jika targetWallet tidak ketemu
            const currentInSystem = targetWallet
              ? targetWallet.currentBalance
              : 0
            const targetBalance = Number(this.newWallet.balance)

            // Cek apakah ada perbedaan saldo (Koreksi Saldo)
            if (targetBalance !== currentInSystem) {
              const diff = targetBalance - currentInSystem

              // Buat transaksi koreksi otomatis
              storage.addTransaction({
                id: 'adj-' + Date.now(),
                type: diff > 0 ? 'income' : 'expense',
                amount: Math.abs(diff),
                walletId: this.editId,
                category: 'Adjustment',
                notes: `Balance Correction: ${oldWallet.name}`,
                date: now,
              })
            }

            // Update data profil wallet-nya
            settings.wallets[index] = {
              ...oldWallet,
              name: this.newWallet.name,
              icon: this.newWallet.icon,
              gradient: this.newWallet.gradient,
              // initial balance (balance) tidak kita ubah agar history tetap konsisten
            }
          }
        } else {
          // --- MODE TAMBAH BARU ---
          const walletData = {
            id: 'w' + Date.now(),
            name: this.newWallet.name,
            balance: Number(this.newWallet.balance), // Ini jadi saldo awal
            icon: this.newWallet.icon,
            gradient: this.newWallet.gradient,
          }
          settings.wallets.push(walletData)
        }

        // Simpan ke storage
        storage.saveSettings(settings)

        // Reset & Close
        this.closeModal() // Pastikan lo punya fungsi reset state di sini
        this.refreshWallets()
      },

      // Fungsi pembantu buat reset modal
      closeModal() {
        this.isModalOpen = false
        this.isEditMode = false
        this.editId = null
        this.newWallet = {
          name: '',
          balance: 0,
          icon: 'fa-wallet',
          colorName: 'blue',
          gradient: 'from-blue-400 to-blue-700',
        }
      },

      deleteWallet() {
        // Cek guard yang sudah kita siapkan di modal
        if (this.transactionCount > 0) {
          alert(
            `Cannot delete wallet! You have ${this.transactionCount} transactions linked to this wallet. Please delete the transactions first.`
          )
          return this.closeModal()
        }

        if (confirm('Are you sure you want to delete this wallet?')) {
          const settings = storage.getSettings()
          settings.wallets = settings.wallets.filter(
            (w: any) => w.id !== this.editId
          )

          storage.saveSettings(settings)
          this.closeModal()
          this.refreshWallets()
        }
      },

      // refreshWallets() {
      //   const settings = storage.getSettings()
      //   const balances = storage.getBalances() as any // Bypass TS check simpel

      //   const walletBalances = balances?.byWallet || {}

      //   this.wallets = settings.wallets.map((w: any) => ({
      //     ...w,
      //     currentBalance: walletBalances[w.id] || 0,
      //   }))
      // },
      refreshWallets() {
        const settings = storage.getSettings() || {}

        // SOLUSI: Kasih '|| []' biar kalau wallets gak ada, dia jadi array kosong, bukan undefined
        const rawWallets = settings.wallets || []

        const balances = storage.getBalances().byWallet as any

        // Sekarang .map gak akan error karena sumbernya minimal []
        this.wallets = rawWallets.map((w: any) => {
          // Hitung jumlah transaksi untuk guard delete
          const transactions = storage.getTransactions() || []
          const count = transactions.filter(
            (t: any) => t.walletId === w.id || t.walletIdDest === w.id
          ).length

          return {
            ...w,
            currentBalance: balances[w.id] || 0,
            transactionCount: count,
          }
        })
      },
    })
  })
</script>

<style>
  [x-cloak] {
    display: none !important;
  }
  .no-scrollbar::-webkit-scrollbar {
    display: none;
  }
  .no-scrollbar {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
</style>
