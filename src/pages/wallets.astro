    <!-- WALLETS LIST -->
    <section>
      <div x-cloak class="space-y-6">
        <template x-if="wallets.length > 0">
          <div class="grid grid-cols-1 gap-6 md:grid-cols-2">
            <template x-for="wallet in wallets" :key="wallet.id">
              <div @click="openEditModal(wallet)">
                <WalletCard />
              </div>
            </template>
            <button
              @click="openAddModal()"
              class="flex w-full flex-col items-center justify-center gap-3 rounded-4xl border-2 border-dashed border-slate-200 bg-slate-50/50 py-12 text-slate-400 transition-all hover:border-indigo-300 hover:text-indigo-400"
            >
              <div
                class="flex h-14 w-14 items-center justify-center rounded-full bg-white shadow-sm"
              >
                <i class="fa-solid fa-plus text-xl"></i>
              </div>
              <span class="text-xs font-bold tracking-widest uppercase"
                >Add New Wallet</span
              >
            </button>
          </div>
        </template>

        <template x-if="wallets.length === 0">
          <EmptyState
            title="No Wallets Yet"
            message="You don't have any wallets connected. Create one to start tracking your balances and transactions."
            icon="fa-building-columns"
            buttonText="Create First Wallet"
            type="button"
            onClick="openAddModal()"
          />
        </template>
      </div>
    </section>

    <!-- WALLET MODAL -->
    <section
      x-show="isModalOpen"
      x-transition.opacity
      class="fixed inset-0 z-99 flex items-end justify-center bg-[#1D1E20]/60 p-4 backdrop-blur-sm sm:items-center"
      x-cloak
    >
      <div
        @click.away="closeModal()"
        x-show="isModalOpen"
        x-transition:enter="transition ease-out duration-300"
        x-transition:enter-start="opacity-0 translate-y-8 sm:scale-95"
        x-transition:enter-end="opacity-100 translate-y-0 sm:scale-100"
        class="no-scrollbar relative max-h-[90vh] w-full max-w-lg overflow-y-auto rounded-4xl bg-white p-8 shadow-2xl"
      >
        <div class="mb-8 flex items-center justify-between">
          <h2 class="font-jakarta text-2xl font-black text-[#1D1E20]">
            New Wallet
          </h2>
          <button
            @click="isModalOpen = false"
            class="text-slate-400 transition-colors hover:text-rose-500"
          >
            <i class="fa-solid fa-xmark text-2xl"></i>
          </button>
        </div>

        <div class="space-y-6">
          <div>
            <label
              class="mb-2 block text-[10px] font-bold tracking-widest text-slate-400 uppercase"
              >Name</label
            >
            <input
              x-model="newWallet.name"
              type="text"
              class="w-full rounded-2xl border-none bg-slate-50 p-4 font-bold focus:ring-2 focus:ring-indigo-500"
              placeholder="e.g. Bank Mandiri"
            />
          </div>

          <div>
            <label
              class="mb-2 block text-[10px] font-bold tracking-widest text-slate-400 uppercase"
              >Initial Balance</label
            >
            <input
              x-model="newWallet.balance"
              type="number"
              placeholder="0"
              class="w-full rounded-2xl border-none bg-slate-50 p-4 font-bold focus:ring-2 focus:ring-indigo-500"
            />
          </div>

          <div>
            <label
              class="mb-2 block text-[10px] font-bold tracking-widest text-slate-400 uppercase"
              >Select Icon</label
            >
            <div class="grid grid-cols-4 gap-3">
              <template x-for="ico in icons">
                <button
                  @click="newWallet.icon = ico.val"
                  class="flex items-center justify-center rounded-2xl border-2 p-4 transition-all"
                  :class="newWallet.icon === ico.val ? 'border-indigo-500 bg-indigo-50 text-indigo-600' : 'border-slate-50 text-slate-400 hover:bg-slate-50'"
                >
                  <i class="fa-solid text-xl" :class="ico.val"></i>
                </button>
              </template>
            </div>
          </div>

          <div>
            <label
              class="mb-2 block text-[10px] font-bold tracking-widest text-slate-400 uppercase"
              >Theme Color</label
            >
            <div class="flex flex-wrap gap-3">
              <template x-for="color in colors">
                <button
                  @click="selectColor(color.name)"
                  class="h-10 w-10 rounded-full border-4 shadow-sm transition-all"
                  :class="[color.bg, newWallet.colorName === color.name ? 'border-slate-800 scale-110 shadow-lg ring-2 ring-slate-100' : 'border-transparent opacity-70 hover:opacity-100']"
                ></button>
              </template>
            </div>
          </div>

          <div class="mt-8 flex gap-3">
            <template x-if="isEditMode">
              <button
                @click="deleteWallet"
                class="flex-1 rounded-2xl bg-rose-50 py-4 text-sm font-bold text-rose-600 transition-all hover:bg-rose-100"
              >
                <i class="fa-solid fa-trash-can mr-2"></i> Delete
              </button>
            </template>

            <button
              @click="saveWallet()"
              class="flex-2 rounded-2xl bg-indigo-600 py-4 text-sm font-bold text-white shadow-lg transition-all"
            >
              <span x-text="isEditMode ? 'Update Wallet' : 'Create Wallet'"
              ></span>
            </button>
          </div>

          <template x-if="isEditMode && transactionCount > 0">
            <p class="mt-4 text-center text-[10px] text-slate-400 italic">
              * Wallet cannot be deleted. You have <span
                class="font-bold text-rose-500"
                x-text="transactionCount"></span> transactions linked.
            </p>
          </template>
        </div>
      </div>
    </section>
  </div>
</MainLayout>

<script>
  import Alpine from 'alpinejs'
  import { walletPage } from '../logic/wallets'

  // Daftarkan ke Alpine
  document.addEventListener('alpine:init', () => {
    Alpine.data('walletPage', walletPage)
  })
</script>

<style>
  [x-cloak] {
    display: none !important;
  }
  .no-scrollbar::-webkit-scrollbar {
    display: none;
  }
  .no-scrollbar {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
</style>
