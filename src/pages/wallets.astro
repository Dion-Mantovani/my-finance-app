---
import MainLayout from '../layouts/MainLayout.astro'
import EmptyState from '../components/shared/EmptyState.astro'
import WalletCard from '../components/wallet/WalletCard.astro'
---

<MainLayout title="My Wallets">
  <div class="mx-auto pb-[15vh]" x-data="walletPage()">
    <!-- HEADER -->
    <header class="mb-8 text-center">
      <h1 class="font-jakarta text-3xl font-extrabold text-[#1D1E20]">
        My Wallets
      </h1>
      <p class="mt-1 text-sm leading-relaxed text-slate-500">
        Manage your sources and set your limits.
      </p>
    </header>

    <section
      class="relative mb-6 overflow-hidden rounded-[2.5rem] border-none bg-indigo-950 p-7 text-white shadow-2xl shadow-indigo-100 dark:shadow-none"
      x-data="{ activeTip: null }"
      @click.away="activeTip = null"
    >
      <div
        class="absolute -top-16 -right-16 h-60 w-60 rounded-full bg-indigo-900 opacity-60"
      >
      </div>
      <div
        class="absolute -bottom-10 -left-10 h-40 w-40 rounded-full bg-indigo-900/50 opacity-40"
      >
      </div>

      <div class="relative z-10 flex flex-col items-start">
        <div class="mb-2 flex w-full items-center justify-between">
          <p
            class="text-[10px] font-bold tracking-[0.2em] uppercase opacity-50"
          >
            My Total Assets
          </p>

          <div class="flex gap-1.5">
            <button
              @click="toggleViewMode()"
              class="flex h-10 w-10 items-center justify-center rounded-full border border-white/10 bg-white/5 backdrop-blur-md transition-all hover:bg-white/10 active:scale-95"
            >
              <template x-if="viewMode === 'list'">
                <i class="fa-solid fa-list text-xs text-indigo-300"></i>
              </template>
              <template x-if="viewMode === 'card'">
                <i class="fa-solid fa-table-cells-large text-xs text-indigo-300"
                ></i>
              </template>
            </button>

            <!-- Tombol Edit Order (Taruh di pojok kanan, samping atau bawah toggle view) -->
            <button
              @click="toggleEditOrder()"
              class="flex h-10 w-10 items-center justify-center rounded-full border border-white/10 bg-white/5 backdrop-blur-md transition-all hover:bg-white/10 active:scale-95"
              :class="isReordering ? 'ring-2 ring-emerald-500 bg-emerald-500/20' : ''"
            >
              <!-- Ikon dinamis: Panah Atas-Bawah saat normal, Centang saat edit -->
              <template x-if="!isReordering">
                <i class="fa-solid fa-sort text-xs text-indigo-300"></i>
              </template>
              <template x-if="isReordering">
                <i class="fa-solid fa-check text-sm text-emerald-400"></i>
              </template>
            </button>
          </div>
        </div>

        <h2 class="text-4xl font-black tracking-tight lg:text-5xl">
          <span class="text-3xl text-white">Rp</span>
          <span
            class="font-jakarta"
            x-text="totalAsset"
            x-show="$store.app.showAmount"></span>
          <span class="font-jakarta" x-show="!$store.app.showAmount" x-cloak
            >••••••••</span
          >
        </h2>

        <div class="mt-6 flex items-center gap-4">
          <div
            class="relative flex cursor-pointer items-center gap-1.5"
            @click.stop="activeTip = activeTip === 'wallet' ? null : 'wallet'"
          >
            <div
              x-cloak
              x-show="activeTip === 'wallet'"
              x-transition
              class="absolute bottom-full left-0 mb-2 rounded-lg bg-white px-2 py-1 text-[9px] font-bold whitespace-nowrap text-indigo-950 shadow-xl"
            >
              Jumlah rekening/dompet aktif
              <div
                class="absolute top-full left-2 border-4 border-transparent border-t-white"
              >
              </div>
            </div>

            <i class="fa-solid fa-wallet text-[10px] text-indigo-400"></i>
            <p
              class="text-[10px] font-bold tracking-wider text-indigo-200 uppercase"
            >
              <span x-text="wallets.length"></span> Wallets
            </p>
          </div>

          <div class="h-3 w-px bg-white/40"></div>

          <div
            class="relative flex cursor-pointer items-center gap-1.5 whitespace-nowrap"
            @click.stop="activeTip = activeTip === 'top' ? null : 'top'"
          >
            <div
              x-cloak
              x-show="activeTip === 'top'"
              x-transition
              class="absolute bottom-full -left-2 mb-2 rounded-lg bg-white px-2 py-1 text-[9px] font-bold whitespace-nowrap text-indigo-950 shadow-xl"
            >
              Penyimpan saldo terbesar saat ini
              <div
                class="absolute top-full left-2 border-4 border-transparent border-t-white"
              >
              </div>
            </div>

            <i class="fa-solid fa-star text-[10px] text-amber-400"></i>
            <p
              class="text-[10px] font-bold tracking-tighter text-indigo-200 uppercase"
            >
              <span x-text="topWalletName"></span>
            </p>
          </div>

          <div class="h-3 w-px bg-white/40"></div>

          <div
            class="relative flex cursor-pointer items-center gap-1.5"
            @click.stop="activeTip = activeTip === 'acts' ? null : 'acts'"
          >
            <div
              x-cloak
              x-show="activeTip === 'acts'"
              x-transition
              class="absolute right-0 bottom-full mb-2 rounded-lg bg-white px-2 py-1 text-[9px] font-bold whitespace-nowrap text-indigo-950 shadow-xl"
            >
              Total catatan transaksi bulan ini
              <div
                class="absolute top-full right-2 border-4 border-transparent border-t-white"
              >
              </div>
            </div>

            <i class="fa-solid fa-chart-line text-[10px] text-emerald-400"></i>
            <p
              class="text-[10px] font-bold tracking-wider text-indigo-200 uppercase"
            >
              <span x-text="totalTransactionsCount"></span> Acts
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- WALLETS LIST -->
    <section>
      <div x-cloak class="space-y-6">
        <template x-if="wallets.length > 0">
          <div
            class="grid grid-cols-1 md:grid-cols-2"
            :class="viewMode === 'list' ? 'gap-3' : 'gap-6'"
          >
            <template x-if="viewMode === 'card'">
              <template x-for="wallet in wallets" :key="wallet.id">
                <div @click="openEditModal(wallet)">
                  <WalletCard />
                </div>
              </template>
            </template>

            <template x-if="viewMode === 'list'">
              <template x-for="(wallet, index) in tempWallets" :key="wallet.id">
                <div @click="openEditModal(wallet)">
                  <div
                    class="flex items-center justify-between rounded-3xl border border-white/5 bg-white/5 p-4 shadow-sm backdrop-blur-md transition-all hover:bg-white/10 active:scale-[0.98]"
                  >
                    <div class="flex items-center gap-4">
                      <div
                        class="flex h-12 w-12 items-center justify-center rounded-2xl border border-white/10 shadow-inner"
                        :class=`{
                          'bg-linear-to-br from-blue-400 to-blue-700': wallet.gradient === 'from-blue-400 to-blue-700',
                          'bg-linear-to-br from-green-400 to-green-700': wallet.gradient === 'from-green-400 to-green-700',
                          'bg-linear-to-br from-rose-400 to-rose-700': wallet.gradient === 'from-rose-400 to-rose-700',
                          'bg-linear-to-br from-amber-400 to-amber-700': wallet.gradient === 'from-amber-400 to-amber-700',
                          'bg-linear-to-br from-indigo-400 to-indigo-700': wallet.gradient === 'from-indigo-400 to-indigo-700',
                          'bg-linear-to-br from-violet-400 to-violet-700': wallet.gradient === 'from-violet-400 to-violet-700',
                          'bg-linear-to-br from-cyan-400 to-cyan-700': wallet.gradient === 'from-cyan-400 to-cyan-700',
                          'bg-linear-to-br from-slate-400 to-slate-700': wallet.gradient === 'from-slate-400 to-slate-700',
                          'bg-slate-900': !wallet.gradient
                        }`
                      >
                        <i
                          class="fa-solid text-xl text-white"
                          :class="wallet.icon || 'fa-wallet'"></i>
                      </div>

                      <div class="flex flex-col gap-1">
                        <p
                          class="text-base font-bold tracking-tight text-indigo-600"
                          x-text="wallet.name"
                        >
                        </p>
                        <div class="flex items-center gap-1.5 opacity-50">
                          <i
                            class="fa-solid fa-receipt text-[8px] text-indigo-300"
                          ></i>
                          <p
                            class="text-[9px] font-black tracking-widest uppercase"
                            x-text="`${wallet.transactionCount} Activities`"
                          >
                          </p>
                        </div>
                      </div>
                    </div>

                    <div class="flex items-center gap-6 text-right">
                      <div class="flex items-baseline justify-end gap-1">
                        <span class="text-[10px] font-bold text-indigo-950/40"
                          >Rp</span
                        >
                        <h4
                          class="font-jakarta text-base font-black tracking-tight text-indigo-950"
                          x-show="$store.app.showAmount"
                          x-text="Number(wallet.currentBalance).toLocaleString('id-ID')"
                        >
                        </h4>
                        <span
                          class="text-base text-indigo-950"
                          x-show="!$store.app.showAmount"
                          x-cloak
                        >
                          ••••
                        </span>
                      </div>

                      <!-- Tombol Panah (Hanya muncul pas Reordering) -->
                      <div
                        x-show="isReordering"
                        x-transition
                        class="flex flex-col gap-1"
                      >
                        <button
                          @click.stop="moveUp(index)"
                          :disabled="index === 0"
                          class="text-indigo-300 hover:text-white disabled:opacity-20"
                        >
                          <i class="fa-solid fa-chevron-up text-[10px]"></i>
                        </button>
                        <button
                          @click.stop="moveDown(index)"
                          :disabled="index === tempWallets.length - 1"
                          class="text-indigo-300 hover:text-white disabled:opacity-20"
                        >
                          <i class="fa-solid fa-chevron-down text-[10px]"></i>
                        </button>
                      </div>
                    </div>
                  </div>
                </div>
              </template>
            </template>

            <button
              @click="openAddModal()"
              class="flex w-full items-center justify-center gap-3 border-2 border-dashed border-slate-200 bg-slate-50/50 text-slate-400 transition-all hover:border-indigo-300 hover:text-indigo-400"
              :class="viewMode === 'list' ? 'py-4 rounded-3xl' : 'flex-col py-12 rounded-4xl'"
            >
              <div
                class="flex items-center justify-center rounded-full bg-white shadow-sm"
                :class="viewMode === 'list' ? 'h-8 w-8' : 'h-14 w-14'"
              >
                <i
                  class="fa-solid fa-plus"
                  :class="viewMode === 'list' ? 'text-base' : 'text-xl'"></i>
              </div>
              <span class="text-xs font-bold tracking-widest uppercase"
                >Add New Wallet</span
              >
            </button>
          </div>
        </template>

        <template x-if="wallets.length === 0">
          <EmptyState
            title="No Wallets Yet"
            message="You don't have any wallets connected. Create one to start tracking your balances and transactions."
            icon="fa-building-columns"
            buttonText="Create First Wallet"
            type="button"
            onClick="openAddModal()"
          />
        </template>
      </div>
    </section>

    <!-- WALLET MODAL -->
    <section
      x-show="isModalOpen"
      x-transition.opacity
      class="fixed inset-0 z-99 flex items-end justify-center bg-[#1D1E20]/60 p-4 backdrop-blur-sm sm:items-center"
      x-cloak
    >
      <div
        @click.away="closeModal()"
        x-show="isModalOpen"
        x-transition:enter="transition ease-out duration-300"
        x-transition:enter-start="opacity-0 translate-y-8 sm:scale-95"
        x-transition:enter-end="opacity-100 translate-y-0 sm:scale-100"
        class="no-scrollbar relative max-h-[90vh] w-full max-w-lg overflow-y-auto rounded-4xl bg-white p-8 shadow-2xl"
      >
        <div class="mb-8 flex items-center justify-between">
          <h2 class="font-jakarta text-2xl font-black text-[#1D1E20]">
            New Wallet
          </h2>
          <button
            @click="isModalOpen = false"
            class="text-slate-400 transition-colors hover:text-rose-500"
          >
            <i class="fa-solid fa-xmark text-2xl"></i>
          </button>
        </div>

        <div class="space-y-6">
          <div>
            <label
              class="mb-2 block text-[10px] font-bold tracking-widest text-slate-400 uppercase"
              >Name</label
            >
            <input
              x-model="newWallet.name"
              type="text"
              class="w-full rounded-2xl border-none bg-slate-50 p-4 font-bold focus:ring-2 focus:ring-indigo-500"
              placeholder="e.g. Bank Mandiri"
            />
          </div>

          <div>
            <label
              class="mb-2 block text-[10px] font-bold tracking-widest text-slate-400 uppercase"
              >Initial Balance</label
            >
            <input
              x-model="newWallet.balance"
              type="number"
              placeholder="0"
              class="w-full rounded-2xl border-none bg-slate-50 p-4 font-bold focus:ring-2 focus:ring-indigo-500"
            />
          </div>

          <div>
            <label
              class="mb-2 block text-[10px] font-bold tracking-widest text-slate-400 uppercase"
              >Select Icon</label
            >
            <div class="grid grid-cols-4 gap-3">
              <template x-for="ico in icons">
                <button
                  @click="newWallet.icon = ico.val"
                  class="flex items-center justify-center rounded-2xl border-2 p-4 transition-all"
                  :class="newWallet.icon === ico.val ? 'border-indigo-500 bg-indigo-50 text-indigo-600' : 'border-slate-50 text-slate-400 hover:bg-slate-50'"
                >
                  <i class="fa-solid text-xl" :class="ico.val"></i>
                </button>
              </template>
            </div>
          </div>

          <div>
            <label
              class="mb-2 block text-[10px] font-bold tracking-widest text-slate-400 uppercase"
              >Theme Color</label
            >
            <div class="flex flex-wrap gap-3">
              <template x-for="color in colors">
                <button
                  @click="selectColor(color.name)"
                  class="h-10 w-10 rounded-full border-4 shadow-sm transition-all"
                  :class="[color.bg, newWallet.colorName === color.name ? 'border-slate-800 scale-110 shadow-lg ring-2 ring-slate-100' : 'border-transparent opacity-70 hover:opacity-100']"
                ></button>
              </template>
            </div>
          </div>

          <div class="mt-8 flex gap-3">
            <template x-if="isEditMode">
              <button
                @click="deleteWallet"
                class="flex-1 rounded-2xl bg-rose-50 py-4 text-sm font-bold text-rose-600 transition-all hover:bg-rose-100"
              >
                <i class="fa-solid fa-trash-can mr-2"></i> Delete
              </button>
            </template>

            <button
              @click="saveWallet()"
              class="flex-2 rounded-2xl bg-indigo-600 py-4 text-sm font-bold text-white shadow-lg transition-all"
            >
              <span x-text="isEditMode ? 'Update Wallet' : 'Create Wallet'"
              ></span>
            </button>
          </div>

          <template x-if="isEditMode && transactionCount > 0">
            <p class="mt-4 text-center text-[10px] text-slate-400 italic">
              * Wallet cannot be deleted. You have <span
                class="font-bold text-rose-500"
                x-text="transactionCount"></span> transactions linked.
            </p>
          </template>
        </div>
      </div>
    </section>
  </div>
</MainLayout>

<script>
  import Alpine from 'alpinejs'
  import { walletPage } from '../logic/wallets'

  // Daftarkan ke Alpine
  document.addEventListener('alpine:init', () => {
    Alpine.data('walletPage', walletPage)
  })
</script>

<style>
  [x-cloak] {
    display: none !important;
  }
  .no-scrollbar::-webkit-scrollbar {
    display: none;
  }
  .no-scrollbar {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
</style>
