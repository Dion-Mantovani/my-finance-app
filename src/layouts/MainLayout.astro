---
import '../styles/global.css'
import Navigation from '../components/shared/Navigation.astro'
const { title = 'DuitKu' } = Astro.props

const currentPath = Astro.url.pathname

// Daftar halaman yang TIDAK boleh ada navigasinya
const hideNavigationPaths = ['/transactions']
const shouldShowNavigation = !hideNavigationPaths.includes(currentPath)
---

<html lang="id">
  <head>
    <meta charset="utf-8" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1, maximum-scale=1, user-scalable=0"
    />
    <title>{title} | DuitKu</title>
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css"
    />
  </head>
  <body
    class="color-app-bg color-app-text font-jakarta min-h-screen overflow-x-hidden"
  >
    <!-- x-data="{ showAmount: localStorage.getItem('showAmount') !== 'false' }"
    x-init="$watch('showAmount', value => localStorage.setItem('showAmount', value))" -->
    <div class="flex">
      {shouldShowNavigation && <Navigation name="Dion Mantovani" />}
      <div class="flex-1">
        <main class="mx-auto max-w-5xl px-6 py-8 md:py-12">
          <slot />
        </main>
      </div>
    </div>

    <div
      x-data="{tempName: '',
                isOpen: false,
                init() {
                  // Buka otomatis jika nama masih 'User' (First Time)
                  if (this.$store.app.user.name === 'User') {
                    this.isOpen = true;
                    this.tempName = '';
                  }
                }
              }"
      @open-user-modal.window="isOpen = true; tempName = $store.app.user.name"
      x-show="isOpen"
      x-cloak
      class="fixed inset-0 z-99 flex items-center justify-center px-6"
    >
      <div
        class="absolute inset-0 bg-slate-900/40 backdrop-blur-sm"
        @click="if($store.app.user.name !== 'User') isOpen = false"
      >
      </div>

      <div
        class="relative w-full max-w-sm rounded-[2.5rem] bg-white p-8 shadow-2xl"
      >
        <div class="mb-6 text-center">
          <div
            class="mx-auto mb-4 flex h-16 w-16 items-center justify-center rounded-2xl bg-indigo-50 text-2xl text-indigo-600"
          >
            <i class="fa-solid fa-user-astronaut"></i>
          </div>
          <h2 class="font-jakarta text-xl font-black text-[#1D1E20]">
            <span
              x-text="$store.app.user.name === 'User' ? 'Welcome!' : 'Edit Profile'"
            ></span>
          </h2>
          <p class="mt-1 text-sm text-slate-500">What should we call you?</p>
        </div>

        <input
          type="text"
          x-model="tempName"
          placeholder="Enter your name..."
          class="mb-6 w-full rounded-2xl border border-slate-100 bg-slate-50 px-5 py-4 font-bold text-[#1D1E20] focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500 focus:outline-none"
        />

        <button
          @click="$store.app.updateUserName(tempName); isOpen = false"
          class="btn-primary w-full py-4 text-sm"
          :disabled="!tempName.trim()"
        >
          Save Changes
        </button>
      </div>
    </div>
  </body>
</html>

<script>
  import { storage } from '../utils/storage'

  const Alpine = (window as any).Alpine

  document.addEventListener('alpine:init', () => {
    Alpine.store('app', {
      user: storage.getSettings().user || { name: 'User' },
      showAmount: storage.getPrivacy(),

      updateUserName(newName: string) {
        const name = newName.trim() || 'User'
        const settings = storage.getSettings()
        settings.user = { name }
        storage.setSettings(settings)
        this.user.name = name

        // Dispatch event biar tab lain tau (optional)
        window.dispatchEvent(new Event('storage'))
      },

      togglePrivacy() {
        this.showAmount = !this.showAmount
        storage.setPrivacy(this.showAmount)
        window.dispatchEvent(new Event('storage'))
      },
    })
  })
</script>
