---
// src/components/BalanceCard.astro
const { incomeValue = 0, expenseValue = 0 } = Astro.props
---

<section
  class="relative mb-2 overflow-hidden rounded-4xl border bg-indigo-950 p-5 text-white shadow-md shadow-slate-100"
>
  <div
    class="absolute -top-16 -right-16 h-60 w-60 rounded-full bg-indigo-900 opacity-60"
  >
  </div>
  <div
    class="absolute -bottom-10 -left-10 h-40 w-40 rounded-full bg-indigo-900/50 opacity-40"
  >
  </div>

  <div class="relative z-10">
    <div class="mb-2.5 flex items-center justify-between">
      <div>
        <p class="text-[11px] font-bold tracking-widest uppercase opacity-60">
          My Total Assets
        </p>
      </div>

      <div class="flex items-center gap-1.5">
        <button
          @click="$store.app.togglePrivacy()"
          class="flex h-10 w-10 items-center justify-center rounded-full border border-white/10 bg-white/5 backdrop-blur-md transition-all hover:bg-white/10 active:scale-95"
        >
          <i
            class="fa-solid text-xs text-indigo-300"
            :class="$store.app.showAmount ? 'fa-eye' : 'fa-eye-slash'"></i>
        </button>

        <button
          class="flex h-10 w-10 items-center justify-center rounded-full border border-white/10 bg-white/5 backdrop-blur-md transition-all hover:bg-white/10 active:scale-95"
          title="Get Report"
        >
          <i class="fa-solid fa-file-export text-xs text-indigo-300"></i>
        </button>
      </div>
    </div>

    <div
      class="flex flex-col gap-6 md:flex-row md:items-end md:justify-between"
    >
      <div>
        <h2 class="text-3xl font-extrabold tracking-tight lg:text-4xl">
          Rp
          <span x-show="$store.app.showAmount" x-text="totalAsset"></span>
          <span x-show="!$store.app.showAmount" x-cloak>••••••••</span>
        </h2>
      </div>
    </div>

    <div class="mt-4 border-t border-white/10 pt-3">
      <p class="mb-2 text-[11px] font-bold tracking-wider uppercase opacity-60">
        This Month Overview
      </p>

      <div class="grid grid-cols-2 items-center gap-4">
        <div class="flex items-center gap-1.5">
          <i class="fa-solid fa-arrow-trend-up text-[10px] text-emerald-400"
          ></i>
          <span class="text-[12px] font-bold text-white">
            <span>Rp</span>
            <span x-show="$store.app.showAmount" x-text={incomeValue}></span>
            <span x-show="!$store.app.showAmount" x-cloak>••••••</span>
          </span>
          <span
            class="rounded bg-emerald-400/50 px-1 text-[9px] font-extrabold tracking-wider text-white uppercase"
            >In</span
          >
        </div>

        <div class="flex items-center gap-1.5">
          <i class="fa-solid fa-arrow-trend-down text-[10px] text-rose-400"></i>
          <span class="text-[12px] font-bold text-white">
            <span>Rp</span>
            <span x-show="$store.app.showAmount" x-text={expenseValue}></span>
            <span x-show="!$store.app.showAmount" x-cloak>••••••</span>
          </span>
          <span
            class="rounded bg-rose-400/50 px-1 text-[9px] font-extrabold tracking-wider text-white uppercase"
            >Out</span
          >
        </div>
      </div>
    </div>
  </div>
</section>
