---
// src/components/UserHeader.astro
const { name = 'User' } = Astro.props
---

<header class="flex items-center justify-between mb-5">
  <div class="flex items-center gap-5">
    <div
      class="w-16 h-16 bg-white border border-slate-100 rounded-full shadow-lg p-0.5 shadow-slate-100 flex items-center justify-center overflow-hidden"
    >
      <img
        src={`https://ui-avatars.com/api/?name=${name}&background=4f46e5&color=fff&rounded=true&bold=true`}
        class="rounded-full"
        alt={name}
      />
    </div>
    <div>
      <p
        class="text-xs font-bold text-slate-400 uppercase tracking-widest mb-1"
      >
        <span x-text="getGreeting().title" class="mr-1"></span><span
          x-text="getGreeting().icon"></span>
      </p>
      <h1
        class="text-3xl font-extrabold text-[#1D1E20] tracking-tight font-jakarta"
      >
        {name}
      </h1>
    </div>
  </div>
  <slot />
</header>
