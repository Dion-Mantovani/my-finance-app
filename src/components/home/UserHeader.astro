---
// src/components/UserHeader.astro
---

<header class="mb-5 flex items-center justify-between">
  <div class="flex items-center gap-3">
    <div
      class="flex h-13 w-13 items-center justify-center overflow-hidden rounded-full border border-slate-100 bg-white p-0.5 shadow-lg shadow-slate-100"
    >
      <img
        :src="`https://ui-avatars.com/api/?name=${$store.app.user.name}&background=4f46e5&color=fff&rounded=true&bold=true`"
        class="rounded-full"
        :alt="$store.app.user.name"
      />
    </div>
    <div class="group cursor-pointer" @click="$dispatch('open-user-modal')">
      <p class="color-app-text text-xs font-medium tracking-wide">
        <span x-text="getGreeting().title" class="mr-1"></span><span
          x-text="getGreeting().icon"></span>
      </p>
      <h1
        class="font-jakarta color-app-text text-2xl font-extrabold tracking-tight transition-colors group-hover:text-indigo-600"
      >
        <span x-text="$store.app.user.name"></span>
        <i
          class="fa-solid fa-pen-to-square ml-1 text-xs opacity-0 transition-opacity group-hover:opacity-100"
        ></i>
      </h1>
    </div>
  </div>
  <slot />
</header>
