---
// src/components/wallet/BudgetCard.astro
---

<div
  class="group relative overflow-hidden rounded-[2.5rem] border border-slate-100 bg-white p-6 shadow-sm"
>
  <div class="mb-4 flex items-start justify-between">
    <div>
      <h4 class="text-lg font-black text-[#1D1E20]" x-text="budget.category">
      </h4>
      <p class="text-[10px] font-bold tracking-widest text-slate-400 uppercase">
        Monthly Limit
      </p>
    </div>
    <div class="text-right">
      <span
        x-show="showAmount"
        class="text-xs font-black text-[#1D1E20]"
        x-text="'Rp ' + Number(budget.limit).toLocaleString('id-ID')"></span>
      <span x-show="!showAmount" x-cloak>••••••</span>
    </div>
  </div>

  <div class="space-y-3">
    <div
      class="flex justify-between text-[10px] font-bold tracking-widest uppercase"
    >
      <span class="text-slate-400"
        >Spent: <span
          x-show="showAmount"
          :class="budget.percentage > 90 ? 'text-rose-500' : 'text-slate-600'"
          x-text="'Rp ' + Number(budget.used).toLocaleString('id-ID')"></span>
        <span x-show="!showAmount" x-cloak>••••••</span>
      </span>
      <span
        :class=`{
          'text-indigo-600': budget.percentage <= 70,
          'text-amber-500': budget.percentage > 70 && budget.percentage <= 90,
          'text-rose-600': budget.percentage > 90
        }`
        x-text="Math.round(budget.percentage) + '%'"></span>
    </div>

    <div class="h-4 w-full overflow-hidden rounded-full bg-slate-100">
      <div
        class="h-full rounded-full transition-all duration-1000 ease-out"
        :class=`{
          'bg-indigo-600': budget.percentage <= 70,
          'bg-amber-400': budget.percentage > 70 && budget.percentage <= 90,
          'bg-rose-500': budget.percentage > 90
        }`
        :style="`width: ${budget.percentage}%`"
      >
      </div>
    </div>

    <p
      class="text-[9px] font-medium text-slate-400 italic"
      x-show="!budget.isOver"
    >
      You have <span
        x-show="showAmount"
        class="font-bold text-emerald-600"
        x-text="'Rp ' + Number(budget.remaining).toLocaleString('id-ID')"
      ></span>
      <span x-show="!showAmount" x-cloak>••••••</span>
      left for this month.
    </p>
    <p class="text-[9px] font-bold text-rose-600 italic" x-show="budget.isOver">
      Overbudget by <span
        x-text="'Rp ' + Number(budget.used - budget.limit).toLocaleString('id-ID')"
      ></span>!
    </p>
  </div>
</div>
