---
// src/components/wallet/WalletCard.astro
---

<div
  class="group relative flex min-h-40 cursor-pointer flex-col justify-between overflow-hidden rounded-4xl p-7 shadow-2xl transition-all active:scale-95"
  :class=`{
    'bg-linear-to-br from-blue-400 to-blue-700': wallet.gradient === 'from-blue-400 to-blue-700',
    'bg-linear-to-br from-green-400 to-green-700': wallet.gradient === 'from-green-400 to-green-700',
    'bg-linear-to-br from-rose-400 to-rose-700': wallet.gradient === 'from-rose-400 to-rose-700',
    'bg-linear-to-br from-amber-400 to-amber-700': wallet.gradient === 'from-amber-400 to-amber-700',
    'bg-linear-to-br from-indigo-400 to-indigo-700': wallet.gradient === 'from-indigo-400 to-indigo-700',
    'bg-linear-to-br from-violet-400 to-violet-700': wallet.gradient === 'from-violet-400 to-violet-700',
    'bg-linear-to-br from-cyan-400 to-cyan-700': wallet.gradient === 'from-cyan-400 to-cyan-700',
    'bg-linear-to-br from-slate-400 to-slate-700': wallet.gradient === 'from-slate-400 to-slate-700',
    'bg-linear-to-br from-green-600 to-green-700': wallet.gradient === 'from-green-600 to-green-700',
    'bg-linear-to-br from-blue-600 to-blue-700': wallet.gradient === 'from-blue-600 to-blue-700',
    'bg-slate-900': !wallet.gradient}`
>
  <div
    class="absolute -top-4 -right-4 h-32 w-32 rounded-full bg-white/10 blur-3xl transition-all group-hover:bg-white/20"
  >
  </div>

  <div
    class="absolute -right-6 -bottom-8 -rotate-12 opacity-10 transition-all duration-500 group-hover:scale-110 group-hover:opacity-25"
  >
    <i
      class="fa-solid text-[11rem] text-white"
      :class="wallet.icon || 'fa-wallet'"></i>
  </div>

  <div class="relative z-10 flex items-start justify-between">
    <div
      class="rounded-2xl border border-white/20 bg-white/20 p-4 shadow-inner backdrop-blur-xl"
    >
      <i
        class="fa-solid text-2xl text-white"
        :class="wallet.icon || 'fa-wallet'"></i>
    </div>
    <div class="text-right">
      <span
        class="mb-1 block text-sm font-black tracking-[0.2em] text-white/80 uppercase"
        x-text="wallet.name"></span>
      <p
        class="text-[10px] font-bold tracking-widest text-white/40 uppercase"
        x-text="wallet.number || '**** **** *809'"
      >
      </p>
    </div>
  </div>

  <div class="relative z-10 mt-8">
    <p
      class="mb-2 text-[10px] font-bold tracking-[0.2em] text-white/60 uppercase text-shadow-sm"
    >
      Available Balance
    </p>
    <div class="flex items-baseline gap-2">
      <span class="text-sm font-bold text-white/50">Rp</span>
      <h3
        class="font-jakarta text-4xl font-black tracking-tight text-white"
        x-show="$store.app.showAmount"
        x-text="Number(wallet.currentBalance).toLocaleString('id-ID')"
      >
      </h3>
      <span class="text-2xl text-white" x-show="!$store.app.showAmount" x-cloak
        >••••••</span
      >
    </div>
  </div>
</div>
