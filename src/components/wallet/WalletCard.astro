---
// src/components/wallet/WalletCard.astro
---

<div
  class="relative p-7 rounded-[2.8rem] overflow-hidden shadow-2xl transition-all active:scale-95 cursor-pointer min-h-55 flex flex-col justify-between group"
  :class=`{
    'bg-linear-to-br from-blue-400 to-blue-700': wallet.gradient === 'from-blue-400 to-blue-700',
    'bg-linear-to-br from-green-400 to-green-700': wallet.gradient === 'from-green-400 to-green-700',
    'bg-linear-to-br from-rose-400 to-rose-700': wallet.gradient === 'from-rose-400 to-rose-700',
    'bg-linear-to-br from-amber-400 to-amber-700': wallet.gradient === 'from-amber-400 to-amber-700',
    'bg-linear-to-br from-indigo-400 to-indigo-700': wallet.gradient === 'from-indigo-400 to-indigo-700',
    'bg-linear-to-br from-violet-400 to-violet-700': wallet.gradient === 'from-violet-400 to-violet-700',
    'bg-linear-to-br from-cyan-400 to-cyan-700': wallet.gradient === 'from-cyan-400 to-cyan-700',
    'bg-linear-to-br from-slate-400 to-slate-700': wallet.gradient === 'from-slate-400 to-slate-700',
    'bg-linear-to-br from-green-600 to-green-700': wallet.gradient === 'from-green-600 to-green-700',
    'bg-linear-to-br from-blue-600 to-blue-700': wallet.gradient === 'from-blue-600 to-blue-700',
    'bg-slate-900': !wallet.gradient}`
>
  <div
    class="absolute -right-4 -top-4 w-32 h-32 bg-white/10 rounded-full blur-3xl group-hover:bg-white/20 transition-all"
  >
  </div>

  <div
    class="absolute -right-6 -bottom-8 opacity-10 group-hover:opacity-25 transition-all duration-500 group-hover:scale-110 -rotate-12"
  >
    <i
      class="fa-solid text-[11rem] text-white"
      :class="wallet.icon || 'fa-wallet'"></i>
  </div>

  <div class="relative flex justify-between items-start z-10">
    <div
      class="bg-white/20 p-4 rounded-2xl backdrop-blur-xl border border-white/20 shadow-inner"
    >
      <i
        class="fa-solid text-white text-2xl"
        :class="wallet.icon || 'fa-wallet'"></i>
    </div>
    <div class="text-right">
      <span
        class="text-white/80 text-sm font-black uppercase tracking-[0.2em] block mb-1"
        x-text="wallet.name"></span>
      <p
        class="text-white/40 text-[10px] font-bold uppercase tracking-widest"
        x-text="wallet.number || '**** **** *809'"
      >
      </p>
    </div>
  </div>

  <div class="relative mt-8 z-10">
    <p
      class="text-white/60 text-[10px] font-bold uppercase tracking-[0.2em] mb-2 text-shadow-sm"
    >
      Available Balance
    </p>
    <div class="flex items-baseline gap-2">
      <span class="text-white/50 text-sm font-bold">Rp</span>
      <h3
        class="text-4xl font-black text-white font-jakarta tracking-tight"
        x-show="showAmount"
        x-text="Number(wallet.currentBalance).toLocaleString('id-ID')"
      >
      </h3>
      <div
        x-show="!showAmount"
        x-cloak
        class="h-10 w-40 bg-white/10 animate-pulse rounded-2xl mt-1"
      >
      </div>
    </div>
  </div>
</div>
