<section class="px-6 mb-10">
  <div class="grid grid-cols-3 gap-4">
    <div
      class="bg-white p-5 rounded-[2.5rem] border border-slate-100 shadow-sm"
    >
      <p
        class="text-[9px] font-bold text-slate-400 uppercase tracking-widest mb-1"
      >
        Income
      </p>
      <h4
        class="text-sm font-black text-emerald-500 font-jakarta"
        x-text="'Rp' + Number(summary.totalIncome).toLocaleString('id-ID')"
      >
      </h4>
    </div>
    <div
      class="bg-white p-5 rounded-[2.5rem] border border-slate-100 shadow-sm"
    >
      <p
        class="text-[9px] font-bold text-slate-400 uppercase tracking-widest mb-1"
      >
        Expense
      </p>
      <h4
        class="text-sm font-black text-rose-500 font-jakarta"
        x-text="'Rp' + Number(summary.totalExpense).toLocaleString('id-ID')"
      >
      </h4>
    </div>
    <div
      class="bg-white p-5 rounded-[2.5rem] border border-slate-100 shadow-sm"
    >
      <p
        class="text-[9px] font-bold text-slate-400 uppercase tracking-widest mb-1"
      >
        Savings
      </p>
      <h4
        class="text-sm font-black text-indigo-600 font-jakarta"
        x-text="summary.savingsRate + '%'"
      >
      </h4>
    </div>
  </div>
</section>
