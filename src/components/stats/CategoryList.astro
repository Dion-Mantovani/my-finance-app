---
// src/components/stats/CategoryList.astro
---

<section class="mb-10" x-data="{ showAll: false }">
  <div class="mb-6">
    <h3 class="font-jakarta text-xl font-black text-[#1D1E20]">Top Spending</h3>
    <p
      class="mt-1 text-[10px] font-bold tracking-widest text-slate-400 uppercase"
    >
      Based on category share
    </p>
  </div>

  <div class="space-y-6">
    <template x-for="(cat, index) in topCategories" :key="cat.name">
      <div
        class="group"
        x-show="index < 5 || showAll"
        x-transition:enter="transition ease-out duration-300"
        x-transition:enter-start="opacity-0 transform -translate-y-2"
        x-transition:enter-end="opacity-100 transform translate-y-0"
      >
        <div class="mb-3 flex items-center justify-between">
          <div class="flex items-center gap-4">
            <div
              class="flex h-12 w-12 items-center justify-center rounded-2xl text-white shadow-sm transition-transform group-hover:scale-105"
              :class="cat.color"
            >
              <i class="fa-solid" :class="cat.icon"></i>
            </div>

            <div>
              <h4 class="text-sm font-black text-[#1D1E20]" x-text="cat.name">
              </h4>
              <div class="mt-0.5 flex items-center gap-1.5">
                <i
                  class="fa-solid text-[10px]"
                  x-show="cat.trendText !== 'Baru bulan ini'"
                  :class="cat.trend === 'up' ? 'fa-arrow-up text-rose-500' : 'fa-arrow-down text-emerald-500'"
                ></i>

                <span
                  class="text-[10px] font-black tracking-tight uppercase"
                  :class=`{
                    'text-rose-500': cat.trend === 'up' && cat.trendText !== 'Baru bulan ini',
                    'text-emerald-500': cat.trend === 'down' && cat.trendText !== 'Baru bulan ini',
                    'text-slate-400': cat.trendText === 'Baru bulan ini'
                  }`
                  x-text="cat.trendText"></span>
              </div>
            </div>
          </div>

          <div class="text-right">
            <p
              x-show="$store.app.showAmount"
              class="text-sm font-black text-[#1D1E20]"
              x-text="'Rp ' + Number(cat.amount).toLocaleString('id-ID')"
            >
            </p>
            <span class="font-jakarta" x-show="!$store.app.showAmount" x-cloak
              >••••••</span
            >

            <p
              class="mt-0.5 text-[9px] font-bold tracking-widest text-slate-400 uppercase"
              x-text="Math.round(cat.percentage) + '% of total'"
            >
            </p>
          </div>
        </div>

        <div class="h-1.5 w-full overflow-hidden rounded-full bg-slate-100">
          <div
            class="h-full rounded-full transition-all duration-1000 ease-out"
            :class="cat.color"
            :style="`width: ${cat.percentage}%`"
          >
          </div>
        </div>
      </div>
    </template>

    <div
      x-show="topCategories.length === 0"
      class="rounded-[2.5rem] border-2 border-dashed border-slate-100 py-10 text-center"
    >
      <p
        class="text-[10px] font-black tracking-widest text-slate-400 uppercase"
      >
        Belum ada data pengeluaran
      </p>
    </div>
  </div>

  <div x-show="topCategories.length > 5" class="mt-10 flex justify-center">
    <button
      @click="showAll = !showAll"
      type="button"
      class="group flex items-center gap-3 rounded-full border border-slate-100 bg-slate-50 px-8 py-3.5 transition-all hover:bg-indigo-50 active:scale-95"
    >
      <span
        class="text-[10px] font-black tracking-[0.2em] text-indigo-600 uppercase"
        x-text="showAll ? 'Sembunyikan' : 'Lihat Semua Kategori'"></span>
      <i
        class="fa-solid text-[10px] text-indigo-600 transition-transform duration-300"
        :class="showAll ? 'fa-chevron-up' : 'fa-chevron-down'"></i>
    </button>
  </div>
</section>
