---
// src/components/stats/StatsHeader.astro
---
<header class="text-center mb-5">
  <h1 class="text-3xl font-extrabold text-[#1D1E20]">Analytics</h1>
  <p class="text-slate-500 text-sm mt-2 leading-relaxed">Gain deep insights into your spending habits and financial health.</p>

  <div class="flex justify-center p-1 bg-slate-100 rounded-4xl mt-6">
    {['Weekly', 'Monthly', 'Yearly'].map((time) => (
      <button
        @click={`timeFrame = '${time}'`}
        class="flex-1 py-3 rounded-3xl text-sm font-bold tracking-wider transition-all"
        :class={`timeFrame === '${time}' ? 'bg-white text-indigo-600 shadow-sm' : 'text-slate-400'`}
      >
        {time}
      </button>
    ))}
  </div>
</header>