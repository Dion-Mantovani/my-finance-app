---
// src/components/budget/BudgetCard.astro
---

<div
  class="group relative overflow-hidden rounded-4xl border border-slate-100 bg-white p-5 shadow-sm transition-all duration-300 hover:shadow-md hover:shadow-slate-100/50"
>
  <div class="mb-3 flex items-start justify-between gap-2">
    <div>
      <h4
        class="text-base font-extrabold tracking-tight text-[#1D1E20] transition-colors group-hover:text-indigo-600"
        x-text="budget.category"
      >
      </h4>

      <p class="flex justify-between gap-1 text-[10px] font-bold uppercase">
        <span class="tracking-widest text-slate-400">Budget:</span>
        <span
          x-show="$store.app.showAmount"
          :class="budget.percentage > 90 ? 'text-rose-600' : 'text-slate-600'"
          x-text="'Rp ' + Number(budget.used || 0).toLocaleString('id-ID')"
        ></span>
        <span x-show="!$store.app.showAmount">•••</span>

        <span class="mx-0.5 opacity-40">/</span>

        <span
          x-show="$store.app.showAmount"
          x-text="'Rp ' + Number(budget.limit).toLocaleString('id-ID')"></span>
        <span x-show="!$store.app.showAmount">•••</span>
      </p>
    </div>

    <div class="text-right">
      <span
        class="text-xs font-black tracking-tight"
        :class=`{
          'text-indigo-600': budget.percentage <= 70,
          'text-amber-500': budget.percentage > 70 && budget.percentage <= 90,
          'text-rose-600': budget.percentage > 90
        }`
        x-text="Math.round(budget.percentage) + '%'"></span>
    </div>
  </div>

  <div class="mb-3">
    <div class="h-2 w-full overflow-hidden rounded-full bg-slate-100 p-px">
      <div
        class="h-full rounded-full transition-all duration-1000 ease-out"
        :class=`{
          'bg-indigo-600': budget.percentage <= 70,
          'bg-amber-400': budget.percentage > 70 && budget.percentage <= 90,
          'bg-rose-500': budget.percentage > 90
        }`
        :style="`width: ${budget.percentage}%`"
      >
      </div>
    </div>
  </div>

  <div class="border-t border-slate-50">
    <p
      class="mb-0 text-[10px] font-medium text-slate-400 italic"
      x-show="!budget.isOver"
    >
      You have
      <span
        x-show="$store.app.showAmount"
        class="non-italic font-extrabold text-emerald-600"
        x-text="'Rp ' + Number(budget.remaining).toLocaleString('id-ID')"
      ></span>
      <span x-show="!$store.app.showAmount">••••••</span>
      left for this month.
    </p>

    <p
      class="mb-0 text-[10px] font-bold text-rose-600 italic"
      x-show="budget.isOver"
    >
      Overbudget by
      <span
        class="non-italic font-extrabold"
        x-text="'Rp ' + Number(budget.used - budget.limit).toLocaleString('id-ID')"
      ></span>!
    </p>
  </div>
</div>

