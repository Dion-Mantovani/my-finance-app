---
// src/components/transaction/AmountDisplay.astro
---

<section class="py-4 text-center shrink-0">
  <div class="flex items-center justify-center gap-1">
    <span class="text-xl font-bold text-slate-300">Rp</span>

    <input
      x-ref="amountInput"
      inputmode="numeric"
      type="number"
      x-model="amount"
      @keydown.enter.prevent="$refs.noteInput.focus()"
      x-effect="$el.style.width = (($el.value.length + 1) * 22) + 'px'"
      class="text-4xl font-black font-jakarta tracking-tight text-[#1D1E20] bg-transparent border-none outline-none text-center focus:ring-0 [appearance:textfield] [&::-webkit-outer-spin-button]:appearance-none [&::-webkit-inner-spin-button]:appearance-none"
      placeholder="0"
      style="transition: width 0.1s ease;"
    />
  </div>
</section>

<style>
  /* Biar inputnya gak ada panah up-down bawaan browser */
  input[type='number'] {
    -moz-appearance: textfield;
    /* min-width: 50px; */
    min-width: 300px;
  }
</style>
