---
// src/components/transactions/CustomSelect.astro
const { label, xModel, options, openState, placeholder, mode, xRef } =
  Astro.props
---

<div class="relative" x-show={Astro.props['x-show'] || 'true'}>
  <label
    class="mb-1 ml-1 block text-[10px] font-bold tracking-widest text-slate-400"
    >{label}</label
  >
  <button
    x-ref={xRef}
    @click={`${openState} = !${openState}`}
    @keydown={`handleKey($event, ${options}, '${mode}')`}
    @click.away={`${openState} = false; activeIndex = -1`}
    type="button"
    class="flex w-full items-center justify-between rounded-xl border border-slate-100 bg-white p-2.5 text-[12px] font-bold text-slate-600 shadow-sm transition-all outline-none focus:border-indigo-500"
  >
    <span x-text={`${xModel} || '${placeholder}'`}></span>
    <i
      class="fa-solid fa-chevron-down text-[10px] transition-transform"
      :class={`${openState} ? 'rotate-180 text-indigo-500' : 'text-slate-300'`}
    ></i>
  </button>

  <div
    x-show={openState}
    class="fixed inset-0 z-100 flex items-end justify-center p-4 sm:items-center"
    x-cloak
  >
    <div
      x-show={openState}
      x-transition:enter="transition ease-out duration-300"
      x-transition:enter-start="opacity-0"
      x-transition:enter-end="opacity-100"
      @click={`${openState} = false`}
      class="absolute inset-0 bg-slate-900/40 backdrop-blur-sm"
    >
    </div>

    <div
      x-show={openState}
      x-transition:enter="transition ease-out duration-300"
      x-transition:enter-start="opacity-0 translate-y-8 sm:scale-95"
      x-transition:enter-end="opacity-100 translate-y-0 sm:scale-100"
      class="relative w-full max-w-sm overflow-hidden rounded-3xl bg-white shadow-2xl"
    >
      <div
        class="flex items-center justify-between border-b border-slate-50 bg-slate-50/50 px-6 py-4"
      >
        <span
          class="text-[11px] font-black tracking-widest text-slate-400 uppercase"
          >Pilih Kategori</span
        >
        <button
          @click={`${openState} = false`}
          class="text-slate-400 hover:text-slate-600"
        >
          <i class="fa-solid fa-xmark"></i>
        </button>
      </div>

      <div class="custom-scrollbar max-h-[60vh] overflow-y-auto">
        <template x-for={`(item, i) in ${options}`} :key="i">
          <div
            @click={`selectValue(item, '${mode}')`}
            :class={`(activeIndex === i || ${xModel} === (typeof item === 'object' ? item.name : item)) ? 'bg-indigo-50 text-indigo-600' : 'text-slate-600'`}
            class="flex cursor-pointer items-center justify-between border-b border-slate-50 px-6 py-4 text-[13px] font-bold transition-colors last:border-none hover:bg-slate-50"
          >
            <span x-text="typeof item === 'object' ? item.name : item"></span>
            <i
              x-show={`activeIndex === i`}
              class="fa-solid fa-check text-[10px]"></i>
          </div>
        </template>
      </div>
    </div>
  </div>

  <!-- <div
    x-show={openState}
    class="absolute z-50 mt-2 w-full overflow-hidden rounded-2xl border border-slate-100 bg-white"
    x-cloak
  >
    <div class="custom-scrollbar max-h-62.5 overflow-y-auto">
      <template x-for={`(item, i) in ${options}`} :key="i">
        <div
          @click={`selectValue(item, '${mode}')`}
          :class={`activeIndex === i ? 'bg-indigo-50 text-indigo-600' : 'text-slate-600'`}
          class="cursor-pointer border-b border-slate-50 px-4 py-3 text-[11px] font-bold transition-colors last:border-none hover:bg-slate-50"
          x-text="typeof item === 'object' ? item.name : item"
        >
        </div>
      </template>
    </div>
  </div> -->
</div>
