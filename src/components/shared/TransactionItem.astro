---
// src/components/shared/TransactionItem.astro

const iconMap = {
  Food: 'fa-utensils',
  Transport: 'fa-car',
  Shopping: 'fa-bag-shopping',
  Groceries: 'fa-basket-shopping',
  Utilities: 'fa-bolt',
  Internet: 'fa-wifi',
  Health: 'fa-heart-pulse',
  Subscription: 'fa-credit-card',
  Entertainment: 'fa-clapperboard',
  Education: 'fa-book-open',
  'Self-Care': 'fa-pump-soap',
  Gift: 'fa-gift',
  Investment: 'fa-chart-line',
  Bonus: 'fa-sack-dollar',
  Salary: 'fa-wallet',
  Freelance: 'fa-laptop-code',
  Other: 'fa-ellipsis',
}
---

<template x-if="item">
  <a
    :href="`/transactions?edit=${item.id}`"
    class="group flex items-center justify-between rounded-2xl border border-slate-100 bg-white p-4 shadow-2xs transition-all active:scale-[0.98] active:bg-slate-50"
  >
    <div class="flex items-center gap-4 text-left">
      <div
        class="flex h-11 w-11 items-center justify-center rounded-2xl text-sm"
        :class=`{
          'bg-emerald-50 text-emerald-500': item.type === 'income',
          'bg-rose-50 text-rose-500': item.type === 'expense',
          'bg-indigo-50 text-indigo-500': item.type === 'transfer'
        }`
      >
        <i
          class="fa-solid"
          :class={`item.type === 'transfer' ? 'fa-right-left' : (${JSON.stringify(iconMap)}[item.category] || 'fa-wallet')`}
        ></i>
      </div>

      <div class="flex flex-col pr-2">
        <p
          class="line-clamp-1 text-sm leading-tight font-bold text-slate-800"
          x-text="item.notes || item.category || 'Transaction'"
        >
        </p>

        <div
          class="mt-0.5 flex"
          :class="item.type === 'transfer'? 'flex-col justify-center gap-0.5' : 'flex-row items-center gap-1.5'"
        >
          <span
            class="text-[10px] font-bold tracking-tight text-indigo-500 uppercase"
            x-text="item.category"></span>
          <span
            class="text-[10px] text-slate-300"
            :class="item.type === 'transfer'? 'hidden' : 'block'">•</span
          >
          <div class="flex items-center gap-1">
            <span
              class="text-[10px] font-medium tracking-wide text-slate-400 uppercase"
              x-text="item.walletSource"></span>

            <template x-if="item.type === 'transfer'">
              <div class="flex items-center gap-1">
                <i class="fa-solid fa-arrow-right text-[8px] text-slate-400"
                ></i>
                <span
                  class="text-[10px] font-medium tracking-wide text-slate-400 uppercase"
                  x-text="item.walletDestName"></span>
              </div>
            </template>
          </div>
        </div>
      </div>
    </div>

    <div class="flex w-28 flex-col items-end">
      <p
        class="text-sm font-black"
        :class=`{
          'text-emerald-500': item.type === 'income',
          'text-rose-500': item.type === 'expense',
          'text-indigo-500': item.type === 'transfer'
        }`
      >
        <span
          x-show="$store.app.showAmount"
          x-text="item.type === 'income' ? '+' : (item.type === 'transfer' ? '' : '-')"
        ></span>
        <span
          x-show="$store.app.showAmount"
          x-text="'Rp ' + Number(item.amount).toLocaleString('id-ID')"></span>
        <span x-show="!$store.app.showAmount" x-cloak>RP •••</span>
      </p>
    </div>
  </a>
</template>
