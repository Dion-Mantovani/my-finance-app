---
// src/components/EmptyState.astro
const {
  title = 'No Data Found',
  message = 'There is no information to display at the moment.',
  buttonText = 'Add New Item',
  icon = 'fa-folder-open', // Default icon
  type = 'button', // 'button' atau 'link'
  link = '#', // Jika type adalah 'link'
  onClick = '', // Jika type adalah 'button' (untuk Alpine.js)
} = Astro.props

// Class CSS yang sama buat Button dan Link biar visualnya seragam
const ctaClasses =
  'flex items-center justify-center gap-2 w-full px-6 py-3 bg-indigo-600 text-white rounded-full text-xs font-bold shadow-lg shadow-indigo-100 hover:bg-indigo-700 transition-all active:scale-95 whitespace-nowrap'
---

<div
  class="flex flex-col items-center justify-center py-6 px-6 text-center w-full"
>
  <div
    class="w-24 h-24 bg-slate-50 rounded-full flex items-center justify-center mb-6"
  >
    <i class={`fa-solid ${icon} text-3xl text-indigo-400`}></i>
  </div>

  <h3 class="text-xl font-extrabold text-[#1D1E20] font-jakarta mb-2">
    {title}
  </h3>
  <p class="text-sm text-slate-400 leading-relaxed max-w-70 mx-auto mb-8">
    {message}
  </p>

  {
    type === 'link' ? (
      <a href={link} class={ctaClasses}>
        <i class="fa-solid fa-plus text-[10px]" />
        {buttonText}
      </a>
    ) : (
      <button @click={onClick} class={ctaClasses}>
        <i class="fa-solid fa-plus text-[10px]" />
        {buttonText}
      </button>
    )
  }
</div>
